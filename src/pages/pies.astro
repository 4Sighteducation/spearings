---
import Layout from '../layouts/Layout.astro';
import { formatPrice, getCatalog, getProductsByCategory } from '../lib/catalog';

const { products } = await getCatalog();
const pieProducts = getProductsByCategory(products, 'pies');
---

<Layout
  title="Pies | Spearings Butchers"
  description="Order Spearings' famous handmade pies online. Baked fresh daily in Macclesfield since 1945 - from classic pork pies to our legendary Macclesfield pasty."
  path="/pies"
>
  <main>
    <section class="page-hero">
      <div class="container page-hero-inner">
        <div class="page-hero-copy stack reveal-left reveal-d1">
          <div class="page-hero-badge">
            <span class="badge-year">Famous Pies</span>
            <span>Handmade daily in Macclesfield</span>
          </div>
          <h1>The pies people <em>come back for</em></h1>
          <p class="body-lead">
            Our pies are handmade fresh every day using quality ingredients and traditional
            recipes. From classic pork pies to our legendary Macclesfield pasty, there's a
            reason customers travel miles for these.
          </p>
          <div class="hero-actions">
            <a href="#pie-range" class="btn btn-gold">Browse Pie Range</a>
            <a href="/visit" class="btn btn-ghost">Visit The Shop</a>
          </div>
        </div>

        <div class="page-visual reveal-right reveal-d2">
          <div class="page-image-frame">
            <img src="/product-images/meat-potato.png" alt="Spearings pie selection" />
          </div>
        </div>
      </div>
    </section>

    <section class="section section-cream">
      <div class="container dual-panels">
        <article class="detail-card reveal-left">
          <p class="eyebrow">Handmade Daily</p>
          <h2>Made fresh at the shop, every morning.</h2>
          <p>
            Every pie is prepared by hand in our Macclesfield shop using recipes perfected over
            decades. We use quality meat and proper pastry - no shortcuts, no compromise.
            That's why customers keep coming back.
          </p>
        </article>

        <article class="detail-card reveal-right reveal-d1">
          <p class="eyebrow">Order Online</p>
          <h2>Collection or delivery to your door.</h2>
          <ul class="bullet-list">
            <li>Choose from the full pie range and order online</li>
            <li>Ideal for family meals, parties, and special occasions</li>
            <li>Hot and cold options available</li>
          </ul>
        </article>
      </div>
    </section>

    <section id="pie-range" class="section section-cream">
      <div class="container">
        <div class="section-header reveal-up">
          <p class="eyebrow">Our Pies</p>
          <h2>The full pie range.</h2>
          <p class="body-lead">
            From everyday favourites to larger celebration pies, here's what's available
            to order. All handmade at the shop, all absolutely worth it.
          </p>
        </div>

        <div class="catalog-grid">
          {pieProducts.map((product) => (
            <article class="catalog-card reveal-scale">
              <div class="catalog-card-media">
                <img src={product.imageUrl ?? '/images/shop-interior.jpg'} alt={product.name} />
              </div>

              <div class="catalog-card-head">
                <div>
                  <h3>{product.name}</h3>
                  {product.size && (
                    <div class="catalog-meta">
                      <span class="meta-pill">{product.size}</span>
                    </div>
                  )}
                </div>

                <div class="catalog-card-price">{formatPrice(product)}</div>
              </div>

              <p>{product.shortDescription ?? 'A Spearings classic, handmade fresh every day.'}</p>
            </article>
          ))}
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  .page-image-frame {
    border-radius: var(--radius-xl);
    overflow: hidden;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.12);
  }

  .page-image-frame img {
    border-radius: 0;
    display: block;
    width: 100%;
  }

  .catalog-card {
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  .catalog-card-media {
    border-radius: var(--radius-md) var(--radius-md) 0 0;
    overflow: hidden;
  }

  .catalog-card-media img {
    display: block;
    width: 100%;
  }

  .detail-card {
    border-radius: var(--radius-lg);
  }
</style>
