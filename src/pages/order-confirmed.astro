---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Order Confirmed | Spearings Butchers"
  description="Your pie order has been placed."
  path="/order-confirmed"
>
  <main>
    <section class="section section-cream">
      <div class="container confirmation-wrap">
        <div class="confirmation-card">
          <div class="confirmation-icon">&#10003;</div>
          <h1>Order Confirmed!</h1>
          <p class="body-lead" id="confirmMsg">
            Thank you for your order. We're preparing your pies now.
          </p>

          <p class="confirm-debug-banner" id="confirmDebugBanner" hidden></p>

          <div class="confirmation-details" id="confirmDetails">
            <div class="confirm-row">
              <span class="confirm-label">Reference</span>
              <strong id="confirmRef">—</strong>
            </div>
          </div>

          <p class="confirm-email-note" id="confirmEmailNote">
            A confirmation email will be sent to your email address shortly.
          </p>

          <div class="confirm-actions">
            <a href="/pies" class="btn btn-gold">Order More Pies</a>
            <a href="/" class="btn btn-ghost btn-ghost-cream">Back to Home</a>
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  .confirmation-wrap {
    display: flex;
    justify-content: center;
    padding: 2rem 0;
  }

  .confirmation-card {
    max-width: 34rem;
    width: 100%;
    text-align: center;
    padding: 3rem 2.5rem;
    border: 1px solid rgba(26, 26, 24, 0.1);
    background: rgba(255, 253, 247, 0.8);
    border-radius: var(--radius-xl);
    box-shadow: 0 12px 40px rgba(26, 26, 24, 0.06);
  }

  .confirmation-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 4rem;
    height: 4rem;
    border-radius: 999px;
    background: var(--g-700);
    color: var(--cream);
    font-size: 1.8rem;
    margin-bottom: 1.5rem;
  }

  .confirmation-card h1 {
    margin-bottom: 0.75rem;
    font-size: 2rem;
  }

  .confirmation-details {
    margin: 2rem 0;
    padding: 1.25rem;
    background: var(--cream-dk);
    border-radius: var(--radius-md);
    text-align: left;
  }

  .confirm-row {
    display: flex;
    justify-content: space-between;
    padding: 0.5rem 0;
    border-bottom: 1px solid rgba(26, 26, 24, 0.08);
    font-size: 0.95rem;
  }

  .confirm-row:last-child {
    border-bottom: none;
  }

  .confirm-label {
    color: var(--ink-soft);
  }

  .confirm-email-note {
    font-size: 0.92rem;
    color: var(--ink-soft);
    margin-bottom: 2rem;
  }

  .confirm-debug-banner {
    font-size: 0.88rem;
    color: #7a2e12;
    background: rgba(255, 220, 200, 0.55);
    border: 1px solid rgba(122, 46, 18, 0.25);
    border-radius: var(--radius-md);
    padding: 0.75rem 1rem;
    margin: 0 0 1.25rem;
    text-align: left;
  }

  .confirm-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn-ghost-cream {
    color: var(--ink);
    border-color: rgba(26, 26, 24, 0.2);
  }

  .btn-ghost-cream:hover {
    border-color: rgba(26, 26, 24, 0.4);
    background: rgba(26, 26, 24, 0.04);
  }
</style>

<script is:inline>
  (function () {
    var params = new URLSearchParams(window.location.search);
    var ref = params.get('ref');
    var paymentIntent = params.get('payment_intent');

    if (ref) {
      document.getElementById('confirmRef').textContent = ref;
    }

    // Clear cart after successful order
    try { localStorage.removeItem('spearings_cart'); } catch (e) {}

    // New checkout session next time (avoid replaying old idempotency keys)
    try {
      sessionStorage.removeItem('spearings_checkout_idem');
      sessionStorage.removeItem('spearings_checkout_fp');
    } catch (e) {}

    // Update badge
    var badge = document.getElementById('cartBadge');
    if (badge) { badge.hidden = true; badge.textContent = '0'; }

    // Confirm payment + send emails (backup if Stripe webhook is delayed or misconfigured)
    var payload = null;
    if (paymentIntent) {
      payload = { payment_intent: paymentIntent };
    } else if (ref) {
      payload = { reference: ref };
    }
    if (payload) {
      fetch('/api/confirm-payment', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'same-origin',
        body: JSON.stringify(payload),
      })
        .then(function (r) {
          return r.json().then(function (data) {
            return { ok: r.ok, status: r.status, data: data };
          });
        })
        .then(function (res) {
          var data = res.data;
          var banner = document.getElementById('confirmDebugBanner');
          var note = document.getElementById('confirmEmailNote');

          if (!res.ok) {
            console.error('[confirm-payment] HTTP', res.status, data);
            if (banner) {
              banner.hidden = false;
              banner.textContent =
                'Could not verify payment with the server (HTTP ' +
                res.status +
                '). Your payment may still be OK — check your email or contact us with reference ' +
                (ref || '') +
                '.';
            }
            return;
          }

          if (data.confirmed && data.emailsSent === false && data.emailError) {
            console.warn('Order confirmed but confirmation email failed:', data.emailError);
            if (banner) {
              banner.hidden = false;
              banner.textContent =
                'Your order is confirmed, but we could not send the confirmation email automatically. ' +
                'Please save your reference above. If you need a receipt, contact us — error: ' +
                data.emailError;
            }
            if (note) {
              note.textContent =
                'If you do not see an email, contact Spearings with your reference — we still have your order.';
            }
          } else if (data.confirmed) {
            console.log('[confirm-payment]', data.path || '', data.emailOutcome || '');
            if (note && data.emailOutcome === 'skipped_already_sent') {
              note.textContent = 'Your confirmation email was already sent — please check your inbox.';
            } else if (note) {
              note.textContent = 'A confirmation email has been sent to your address.';
            }
          } else if (data.phase === 'no_transition') {
            console.warn('[confirm-payment] No DB transition:', data);
            if (banner) {
              banner.hidden = false;
              banner.textContent =
                'We could not link this page to your order in our system. If you were charged, contact us with your bank reference and date.';
            }
          }
        })
        .catch(function (err) {
          console.error('Confirm payment error:', err);
        });
    }
  })();
</script>