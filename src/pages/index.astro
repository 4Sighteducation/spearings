---
export const prerender = true;
import Layout from '../layouts/Layout.astro';
import { getCatalog, getProductsByCategory } from '../lib/catalog';
const { categories, products } = await getCatalog();
const pieCount = getProductsByCategory(products, 'pies').length;

const categoryLinks = {
  meat: '/products#meat',
  pies: '/pies',
  deli: '/products#deli',
  cheese: '/products#cheese',
};

const categoryDescriptions: Record<string, string> = {
  meat: 'Locally sourced, matured and prepared to ensure maximum taste. We display the source of our meat behind the counter.',
  pies: 'Handmade daily and famous across Macclesfield - from classic pork pies to our legendary Macclesfield pasty.',
  deli: 'Cooked meats, savouries, sauces, chutneys, and homemade treats including our delicious vanilla slices.',
  cheese: 'A wide range of cheeses from local producers across the North West and the UK.',
};
---

<Layout
  title="Spearings Butchers | Macclesfield Since 1945"
  description="Traditional family butchers in Macclesfield since 1945. Locally sourced quality meat, handmade pies, deli favourites and regional cheeses."
  path="/"
>
  <main>
    <section class="hero hero-home">
      <div class="container">
        <div class="hero-grid">
          <div class="hero-copy stack">
            <div class="hero-banner">
              <img src="/images/site-logo-banner.png" alt="Spearings Quality Family Butcher banner logo" />
            </div>

            <span class="hero-pill">Since 1945</span>

            <h1>Famous pies, quality meat, and <em>proper family service</em></h1>

            <p class="hero-lead">
              Four generations serving Macclesfield with locally sourced meat,
              handmade pies, and the kind of personal service you only get from a family butcher.
            </p>

            <div class="hero-actions">
              <a href="/pies" class="btn btn-gold">Order Pies Online</a>
              <a href="/products" class="btn btn-ghost">Browse Our Range</a>
            </div>
          </div>

          <div class="hero-visual">
            <div class="hero-visual-main">
              <img src="/images/shop-interior.jpg" alt="Inside Spearings butcher shop" />
            </div>
            <div class="hero-visual-thumb">
              <img src="/images/shop-history.jpg" alt="Historic Spearings shop photograph" />
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="trust-strip">
      <div class="container trust-grid">
        <article class="trust-item reveal-up">
          <div class="trust-num">1945</div>
          <div>
            <strong>Established</strong>
            <p>Founded by Denis Spearing when he returned from the war.</p>
          </div>
        </article>

        <article class="trust-item reveal-up reveal-delay-1">
          <div class="trust-num">4</div>
          <div>
            <strong>Generations</strong>
            <p>Still family-run, now led by Marshall's daughters.</p>
          </div>
        </article>

        <article class="trust-item reveal-up reveal-delay-2">
          <div class="trust-num">{pieCount}</div>
          <div>
            <strong>Handmade pies</strong>
            <p>Baked fresh daily and available for delivery to your door.</p>
          </div>
        </article>

        <article class="trust-item reveal-up reveal-delay-3">
          <div class="trust-num">Local</div>
          <div>
            <strong>Sourced with care</strong>
            <p>We support local farmers and always display provenance behind the counter.</p>
          </div>
        </article>
      </div>
    </section>

    <section class="section section-cream">
      <div class="container story-grid">
        <div class="stack reveal-left">
          <p class="eyebrow">Our Story</p>
          <h2>Serving Macclesfield since 1945.</h2>
          <p class="body-lead">
            Denis William Spearing returned from the war, put down £100, and opened a butcher's
            shop on Cross Street. Eighty years later, his family is still behind the counter at
            12 Park Green.
          </p>
          <p>
            From those beginnings came a passion for quality that has never wavered - farming
            their own livestock at Kinderfield's Farm in Sutton, and building the handmade pie
            reputation that customers travel miles for today.
          </p>
          <a href="/our-story" class="card-link">Read the family story</a>
        </div>

        <div class="reveal-right reveal-d1">
          <div class="story-image-frame">
            <img src="/images/shopfront-history.png" alt="Historic Spearings storefront" />
          </div>
          <div class="story-caption">
            <span class="caption-year">Established</span>
            <span class="caption-num">1945</span>
            <span class="caption-place">Park Green, Macclesfield</span>
          </div>
        </div>
      </div>
    </section>

    <section class="section section-dark">
      <div class="container">
        <div class="section-header-center reveal-up">
          <p class="eyebrow eyebrow-gold">Our Products</p>
          <h2>Quality you can see, taste, and trust.</h2>
        </div>

        <div class="product-grid">
          {
            categories.map((category) => (
              <article class="product-card reveal-scale">
                <div class="product-icon">{category.name}</div>
                <h3>{category.name}</h3>
                <p>
                  {categoryDescriptions[category.slug] ??
                    `Quality ${category.name.toLowerCase()} selected and prepared at the shop.`}
                </p>
                <a
                  href={categoryLinks[category.slug as keyof typeof categoryLinks] ?? '/products'}
                  class="card-link"
                >
                  {category.slug === 'pies' ? 'Order Pies Online' : `View ${category.name}`}
                </a>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section class="section section-cream">
      <div class="container">
        <div class="order-online-panel order-panel reveal-up">
          <div class="order-online-grid">
            <div class="order-online-copy stack">
              <p class="eyebrow">Order Online</p>
              <h2 class="order-online-heading">
                <span class="order-online-lead">Handmade daily</span>
                <span class="order-online-head-rest"> — our pies, <em>delivered to you</em>.</span>
              </h2>
              <p>
                Every pie is <strong>handmade daily</strong> at our Macclesfield shop. Take your pick
                from a wide range of hot and cold options, then have them delivered straight to your
                door or ready to collect. Perfect for family meals, parties, or just because you
                deserve a proper pie — including show-stoppers like our Special Occasion pie.
              </p>
              <ul class="bullet-list">
                <li>Choose from the full pie range online</li>
                <li>Collection or delivery available</li>
                <li>Ideal for family meals, parties, and events</li>
              </ul>
              <a href="/pies" class="btn btn-green">Order Pies</a>
            </div>
            <figure class="order-online-visual">
              <div class="order-online-frame">
                <img
                  src="/images/special-occasion-pie.png"
                  alt="Spearings Special Occasion pie — decorated pastry top, handmade daily"
                  width="2048"
                  height="1013"
                  loading="lazy"
                />
              </div>
              <figcaption class="order-online-caption">Special Occasion pie</figcaption>
            </figure>
          </div>
        </div>
      </div>
    </section>

    <section class="section section-deep pwa-promo-section">
      <div class="container">
        <div class="pwa-promo reveal-up">
          <div class="pwa-promo-content">
            <div class="pwa-promo-icon-wrap">
              <img src="/icons/icon-192x192.png" alt="Spearings Pies app icon" class="pwa-promo-app-icon" />
            </div>
            <div class="pwa-promo-copy">
              <p class="eyebrow eyebrow-gold">Get The App</p>
              <h2>Order pies straight from your phone.</h2>
              <p>
                Download the Spearings Pies app to your home screen for instant access
                to our full pie range, quick reordering, and a faster checkout.
                No app store needed — works on iPhone and Android.
              </p>
              <div class="pwa-promo-steps">
                <div class="pwa-step">
                  <span class="pwa-step-num">1</span>
                  <span>Visit <strong>spearings.co.uk/pies</strong> on your phone</span>
                </div>
                <div class="pwa-step">
                  <span class="pwa-step-num">2</span>
                  <span>Tap <strong>Share</strong> then <strong>"Add to Home Screen"</strong></span>
                </div>
                <div class="pwa-step">
                  <span class="pwa-step-num">3</span>
                  <span>Open the app and <strong>start ordering</strong></span>
                </div>
              </div>
              <a href="/pies" class="btn btn-gold">Order Pies Now</a>
            </div>
          </div>
          <div class="pwa-promo-visual reveal-right reveal-d2">
            <div class="pwa-phone-mock">
              <div class="pwa-phone-notch"></div>
              <div class="pwa-phone-screen">
                <div class="pwa-phone-header">
                  <img src="/images/crest-logo-header-new.png" alt="" class="pwa-phone-logo" />
                  <span>Spearings Pies</span>
                </div>
                <div class="pwa-phone-content">
                  <div class="pwa-phone-card"></div>
                  <div class="pwa-phone-card"></div>
                  <div class="pwa-phone-card short"></div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="section section-deep">
      <div class="container testimonial-grid">
        <blockquote class="testimonial reveal-up">
          <p>"Great traditional butchers, friendly service and the Macclesfield pasty is superb."</p>
          <footer>Local customer review</footer>
        </blockquote>

        <blockquote class="testimonial reveal-up reveal-delay-1">
          <p>"Really delicious meats and very friendly and helpful staff."</p>
          <footer>Local customer review</footer>
        </blockquote>

        <blockquote class="testimonial reveal-up reveal-delay-2">
          <p>"Finally had a Spearings pork pie and I'm happier than I have any right to be."</p>
          <footer>Local customer review</footer>
        </blockquote>
      </div>
    </section>

    <section class="section section-cream">
      <div class="container visit-grid">
        <div class="visit-card stack reveal-left">
          <p class="eyebrow">Visit The Shop</p>
          <h2>Find us at 12 Park Green, Macclesfield.</h2>
          <p>
            Pop in and see us - whether it's your weekly shop, a last-minute dinner decision,
            or you just want to browse what's on the counter. We're always happy to help.
          </p>
          <a href="/visit" class="card-link">Plan your visit</a>
        </div>

        <div class="visit-card detail-list reveal-right reveal-d1">
          <div>
            <strong>Address</strong>
            <span>12 Park Green, Macclesfield, Cheshire, SK11 7NA</span>
          </div>
          <div>
            <strong>Phone</strong>
            <span>01625 424395</span>
          </div>
          <div>
            <strong>Email</strong>
            <span>admin@spearings.co.uk</span>
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  .hero-home {
    position: relative;
    padding: clamp(2rem, 4.5vw, 3.5rem) 0 clamp(3rem, 5.5vw, 4.5rem);
  }

  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 1.1fr);
    gap: clamp(2rem, 4vw, 3.5rem);
    align-items: start;
  }

  .hero-copy {
    max-width: 38rem;
  }

  .hero-banner {
    padding: clamp(0.75rem, 1.6vw, 1.15rem) clamp(0.85rem, 2vw, 1.4rem);
    border-radius: var(--radius-xl);
    background: linear-gradient(180deg, rgba(255, 253, 247, 0.995), rgba(249, 243, 226, 0.98));
    box-shadow:
      0 0 0 6px rgba(255, 253, 247, 0.92),
      0 10px 32px rgba(0, 0, 0, 0.2),
      0 0 60px rgba(201, 154, 26, 0.25),
      0 0 120px rgba(201, 154, 26, 0.1),
      inset 0 1px 0 rgba(255, 255, 255, 0.55);
    animation:
      heroBanner 0.8s cubic-bezier(0.22, 1, 0.36, 1) 0.05s both,
      glowPulse 4s ease-in-out 0.85s infinite;
  }

  .hero-banner img {
    width: 100%;
    height: auto;
    max-height: clamp(6rem, 11vw, 9rem);
    object-fit: contain;
  }

  .hero-pill {
    display: inline-block;
    padding: 0.35rem 0.9rem;
    border-radius: 999px;
    border: 1px solid rgba(201, 154, 26, 0.35);
    background: rgba(201, 154, 26, 0.1);
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--gold-lt);
    animation: heroFade 0.6s cubic-bezier(0.22, 1, 0.36, 1) 0.2s both;
  }

  .hero-copy h1 {
    font-size: clamp(2.4rem, 3.8vw, 4rem);
    line-height: 1.04;
    letter-spacing: -0.02em;
    text-wrap: balance;
    animation: heroHeadline 0.9s cubic-bezier(0.22, 1, 0.36, 1) 0.25s both;
  }

  .hero-copy .hero-lead {
    max-width: 36rem;
    animation: heroFade 0.7s cubic-bezier(0.22, 1, 0.36, 1) 0.4s both;
  }

  .hero-actions {
    animation: heroFade 0.7s cubic-bezier(0.22, 1, 0.36, 1) 0.5s both;
  }

  .hero-visual {
    position: relative;
    padding-bottom: 1.5rem;
    padding-left: 1.5rem;
    animation: heroPhoto 1s cubic-bezier(0.22, 1, 0.36, 1) 0.15s both;
  }

  .hero-visual-main {
    overflow: hidden;
    border-radius: var(--radius-xl);
    border: 1px solid rgba(201, 154, 26, 0.22);
    box-shadow:
      0 28px 70px rgba(0, 0, 0, 0.4),
      0 0 0 1px rgba(201, 154, 26, 0.08);
    aspect-ratio: 3 / 4;
  }

  .hero-visual-main img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero-visual-thumb {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 44%;
    aspect-ratio: 0.85;
    overflow: hidden;
    border-radius: var(--radius-lg);
    border: 3px solid rgba(245, 237, 216, 0.4);
    outline: 1px solid rgba(201, 154, 26, 0.22);
    box-shadow: 0 18px 48px rgba(0, 0, 0, 0.38);
    z-index: 2;
    animation: heroFloat 0.8s cubic-bezier(0.22, 1, 0.36, 1) 0.45s both;
  }

  .hero-visual-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 60% center;
  }

  @keyframes heroBanner {
    from {
      opacity: 0;
      transform: scale(0.94) translateY(12px);
      box-shadow:
        0 0 0 6px rgba(255, 253, 247, 0.5),
        0 10px 32px rgba(0, 0, 0, 0.1),
        0 0 0px rgba(201, 154, 26, 0),
        0 0 0px rgba(201, 154, 26, 0),
        inset 0 1px 0 rgba(255, 255, 255, 0.55);
    }
    to {
      opacity: 1;
      transform: scale(1) translateY(0);
      box-shadow:
        0 0 0 6px rgba(255, 253, 247, 0.92),
        0 10px 32px rgba(0, 0, 0, 0.2),
        0 0 60px rgba(201, 154, 26, 0.25),
        0 0 120px rgba(201, 154, 26, 0.1),
        inset 0 1px 0 rgba(255, 255, 255, 0.55);
    }
  }

  @keyframes glowPulse {
    0%, 100% {
      box-shadow:
        0 0 0 6px rgba(255, 253, 247, 0.92),
        0 10px 32px rgba(0, 0, 0, 0.2),
        0 0 60px rgba(201, 154, 26, 0.25),
        0 0 120px rgba(201, 154, 26, 0.1),
        inset 0 1px 0 rgba(255, 255, 255, 0.55);
    }
    50% {
      box-shadow:
        0 0 0 6px rgba(255, 253, 247, 0.92),
        0 10px 32px rgba(0, 0, 0, 0.2),
        0 0 80px rgba(201, 154, 26, 0.32),
        0 0 150px rgba(201, 154, 26, 0.14),
        inset 0 1px 0 rgba(255, 255, 255, 0.55);
    }
  }

  @keyframes heroHeadline {
    from {
      opacity: 0;
      transform: translateY(28px);
      letter-spacing: 0.01em;
    }
    to {
      opacity: 1;
      transform: translateY(0);
      letter-spacing: -0.02em;
    }
  }

  @keyframes heroFade {
    from {
      opacity: 0;
      transform: translateY(14px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes heroPhoto {
    from {
      opacity: 0;
      transform: translateY(40px) scale(0.95) rotate(1deg);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1) rotate(0deg);
    }
  }

  @keyframes heroFloat {
    from {
      opacity: 0;
      transform: translate(-20px, 20px) rotate(-2deg) scale(0.9);
    }
    to {
      opacity: 1;
      transform: translate(0, 0) rotate(0deg) scale(1);
    }
  }

  /* PWA promo section */
  .pwa-promo-section {
    padding: clamp(3.5rem, 7vw, 5.5rem) 0;
  }

  .pwa-promo {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: clamp(2rem, 4vw, 4rem);
    align-items: center;
  }

  .pwa-promo-icon-wrap {
    margin-bottom: 1.25rem;
  }

  .pwa-promo-app-icon {
    width: 4.5rem;
    height: 4.5rem;
    border-radius: var(--radius-lg);
    border: 2px solid rgba(201, 154, 26, 0.3);
    box-shadow:
      0 8px 24px rgba(0, 0, 0, 0.3),
      0 0 40px rgba(201, 154, 26, 0.15);
  }

  .pwa-promo-copy h2 {
    margin-bottom: 0.75rem;
  }

  .pwa-promo-copy > p {
    max-width: 38rem;
  }

  .pwa-promo-steps {
    display: grid;
    gap: 0.75rem;
    margin: 1.5rem 0 2rem;
  }

  .pwa-step {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    padding: 0.75rem 1rem;
    border-radius: var(--radius-md);
    border: 1px solid rgba(201, 154, 26, 0.18);
    background: rgba(201, 154, 26, 0.06);
    color: rgba(245, 237, 216, 0.9);
    font-size: 0.95rem;
  }

  .pwa-step-num {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: 999px;
    background: var(--gold);
    color: var(--g-900);
    font-weight: 700;
    font-size: 0.85rem;
    flex-shrink: 0;
  }

  .pwa-phone-mock {
    position: relative;
    width: 16rem;
    margin: 0 auto;
    padding: 0.75rem;
    border-radius: 2.5rem;
    background: linear-gradient(180deg, #1a1a1a, #111);
    box-shadow:
      0 24px 60px rgba(0, 0, 0, 0.5),
      inset 0 1px 0 rgba(255, 255, 255, 0.08);
  }

  .pwa-phone-notch {
    position: absolute;
    top: 0.5rem;
    left: 50%;
    transform: translateX(-50%);
    width: 5rem;
    height: 1.5rem;
    border-radius: 0 0 1rem 1rem;
    background: #111;
    z-index: 2;
  }

  .pwa-phone-screen {
    border-radius: 1.75rem;
    overflow: hidden;
    background: var(--g-800);
    padding: 2.5rem 1rem 1.5rem;
  }

  .pwa-phone-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid rgba(201, 154, 26, 0.2);
  }

  .pwa-phone-logo {
    width: 1.75rem;
    height: 1.75rem;
    border-radius: 6px;
    object-fit: contain;
    background: rgba(255, 253, 247, 0.95);
    padding: 2px;
  }

  .pwa-phone-header span {
    color: var(--cream);
    font-weight: 700;
    font-size: 0.78rem;
    letter-spacing: 0.04em;
  }

  .pwa-phone-content {
    display: grid;
    gap: 0.6rem;
  }

  .pwa-phone-card {
    height: 4rem;
    border-radius: var(--radius-md);
    background: linear-gradient(135deg, rgba(201, 154, 26, 0.12), rgba(201, 154, 26, 0.05));
    border: 1px solid rgba(201, 154, 26, 0.15);
  }

  .pwa-phone-card.short {
    height: 2.5rem;
  }

  @media (max-width: 980px) {
    .pwa-promo {
      grid-template-columns: 1fr;
    }

    .pwa-promo-visual {
      display: none;
    }
  }

  @media (max-width: 980px) {
    .hero-grid {
      grid-template-columns: 1fr;
    }

    .hero-copy {
      max-width: none;
    }

    .hero-copy h1 {
      max-width: 20ch;
    }

    .hero-visual {
      max-width: 28rem;
      margin-inline: auto;
    }

    .hero-visual-thumb {
      width: 38%;
    }
  }

  @media (max-width: 560px) {
    .hero-copy h1 {
      font-size: clamp(2rem, 7vw, 2.6rem);
    }

    .hero-visual-thumb {
      width: 35%;
    }

    .hero-visual {
      margin-bottom: 1rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-banner,
    .hero-pill,
    .hero-copy h1,
    .hero-copy .hero-lead,
    .hero-actions,
    .hero-visual,
    .hero-visual-thumb {
      animation: none !important;
    }
  }
</style>

