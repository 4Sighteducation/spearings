---
import Layout from '../layouts/Layout.astro';
import { formatPrice, getCatalog, getProductsByCategory } from '../lib/catalog';
import heroBannerLogo from '../../../assets/site-logo-banner.png';
const { categories, products } = await getCatalog();
const pieCount = getProductsByCategory(products, 'pies').length;
const pieProducts = getProductsByCategory(products, 'pies').slice(0, 4);

const categoryLinks = {
  meat: '/products#meat',
  pies: '/pies',
  deli: '/products#deli',
  cheese: '/products#cheese',
};

const categoryDescriptions: Record<string, string> = {
  meat: 'Locally sourced, matured and prepared to ensure maximum taste. We display the source of our meat behind the counter.',
  pies: 'Handmade daily and famous across Macclesfield - from classic pork pies to our legendary Macclesfield pasty.',
  deli: 'Cooked meats, savouries, sauces, chutneys, and homemade treats including our delicious vanilla slices.',
  cheese: 'A wide range of cheeses from local producers across the North West and the UK.',
};
---

<Layout
  title="Spearings Butchers | Macclesfield Since 1945"
  description="Traditional family butchers in Macclesfield since 1945. Locally sourced quality meat, handmade pies, deli favourites and regional cheeses."
  path="/"
>
  <main>
    <section class="hero">
      <div class="container hero-brand-wrap">
        <div class="hero-brand-banner reveal-scale">
          <img src={heroBannerLogo.src} alt="Spearings Quality Family Butcher banner logo" />
        </div>
      </div>

      <div class="container hero-inner">
        <div class="stack home-hero-copy reveal-left reveal-d1">

          <div class="hero-badge">
            <span class="badge-year">Since 1945</span>
            <span class="gold-rule"></span>
            <span>Traditional family butchers in Macclesfield</span>
          </div>

          <h1>
            <span class="hero-title-main">Quality local meat, famous pies, and</span>
            <em>proper family service</em>
          </h1>

          <p class="hero-lead">
            Spearings has been serving Macclesfield for 80 years with locally sourced meat,
            handmade pies, and the kind of personal service you only get from a family butcher.
          </p>

          <div class="hero-actions">
            <a href="/pies" class="btn btn-gold">Order Pies Online</a>
            <a href="/products" class="btn btn-ghost">Browse Our Range</a>
          </div>

          <ul class="hero-pillars">
            <li>Locally sourced meat from farms we know and trust</li>
            <li>Handmade pies, baked fresh every day</li>
            <li>Four generations of family butchery in Macclesfield</li>
          </ul>
        </div>

        <div class="hero-media reveal-right reveal-d2">
          <div class="media-frame media-main hero-photo hero-photo-main">
            <img src="/images/shop-interior.jpg" alt="Inside Spearings butcher shop" />
          </div>

          <div class="media-frame media-float hero-photo hero-photo-float">
            <img src="/images/shop-history.jpg" alt="Historic Spearings shop photograph" />
          </div>

          <div class="media-badge">
            <span class="media-badge-year">Family run</span>
            <span class="media-badge-num">80 years</span>
          </div>
        </div>
      </div>
    </section>

    <section class="trust-strip">
      <div class="container trust-grid">
        <article class="trust-item reveal-up">
          <div class="trust-num">1945</div>
          <div>
            <strong>Established</strong>
            <p>Founded by Denis Spearing when he returned from the war.</p>
          </div>
        </article>

        <article class="trust-item reveal-up reveal-delay-1">
          <div class="trust-num">4</div>
          <div>
            <strong>Generations</strong>
            <p>Still family-run, now led by Marshall's daughters.</p>
          </div>
        </article>

        <article class="trust-item reveal-up reveal-delay-2">
          <div class="trust-num">{pieCount}</div>
          <div>
            <strong>Handmade pies</strong>
            <p>Baked fresh daily and available for delivery to your door.</p>
          </div>
        </article>

        <article class="trust-item reveal-up reveal-delay-3">
          <div class="trust-num">Local</div>
          <div>
            <strong>Sourced with care</strong>
            <p>We support local farmers and always display provenance behind the counter.</p>
          </div>
        </article>
      </div>
    </section>

    <section class="section section-cream">
      <div class="container story-grid">
        <div class="stack reveal-left">
          <p class="eyebrow">Our Story</p>
          <h2>Serving Macclesfield since 1945.</h2>
          <p class="body-lead">
            Denis William Spearing returned from the war, put down £100, and opened a butcher's
            shop on Cross Street. Eighty years later, his family is still behind the counter at
            12 Park Green.
          </p>
          <p>
            From those beginnings came a passion for quality that has never wavered - farming
            their own livestock at Kinderfield's Farm in Sutton, and building the handmade pie
            reputation that customers travel miles for today.
          </p>
          <a href="/our-story" class="card-link">Read the family story</a>
        </div>

        <div class="reveal-right reveal-d1">
          <div class="story-image-frame">
            <img src="/images/shopfront-history.png" alt="Historic Spearings storefront" />
          </div>
          <div class="story-caption">
            <span class="caption-year">Established</span>
            <span class="caption-num">1945</span>
            <span class="caption-place">Park Green, Macclesfield</span>
          </div>
        </div>
      </div>
    </section>

    <section class="section section-dark">
      <div class="container">
        <div class="section-header-center reveal-up">
          <p class="eyebrow eyebrow-gold">Our Products</p>
          <h2>Quality you can see, taste, and trust.</h2>
        </div>

        <div class="product-grid">
          {
            categories.map((category) => (
              <article class="product-card reveal-scale">
                <div class="product-icon">{category.name}</div>
                <h3>{category.name}</h3>
                <p>
                  {categoryDescriptions[category.slug] ??
                    `Quality ${category.name.toLowerCase()} selected and prepared at the shop.`}
                </p>
                <a
                  href={categoryLinks[category.slug as keyof typeof categoryLinks] ?? '/products'}
                  class="card-link"
                >
                  {category.slug === 'pies' ? 'Order Pies Online' : `View ${category.name}`}
                </a>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section class="section section-cream">
      <div class="container pie-grid">
        <div class="pie-menu-card reveal-left">
          <div class="pie-menu-header">
            <span class="pie-menu-rule"></span>
            <div class="pie-menu-title">
              <p class="eyebrow">Famous Pies</p>
              <h2>Handmade daily, delivered to your door.</h2>
            </div>
            <span class="pie-menu-rule"></span>
          </div>

          <div class="pie-list">
            {pieProducts.map((product) => (
              <div class="pie-item">
                <div>
                  <strong>{product.name}</strong>
                  <div class="pie-desc">
                    {product.shortDescription ??
                      'A Spearings classic, handmade fresh every day at the shop.'}
                  </div>
                </div>
                <div class="pie-price">{formatPrice(product)}</div>
              </div>
            ))}
          </div>
        </div>

        <div class="order-panel stack reveal-right reveal-d1">
          <p class="eyebrow">Order Online</p>
          <h2>Our pies, <em>delivered to you</em>.</h2>
          <p>
            Take your pick from a wide range of hot and cold options, handmade daily and
            delivered straight to your door. Perfect for family meals, parties, or just because
            you deserve a proper pie.
          </p>
          <ul class="bullet-list">
            <li>Choose from the full pie range online</li>
            <li>Collection or delivery available</li>
            <li>Ideal for family meals, parties, and events</li>
          </ul>
          <a href="/pies" class="btn btn-green">Order Pies</a>
        </div>
      </div>
    </section>

    <section class="section section-deep">
      <div class="container testimonial-grid">
        <blockquote class="testimonial reveal-up">
          <p>"Great traditional butchers, friendly service and the Macclesfield pasty is superb."</p>
          <footer>Local customer review</footer>
        </blockquote>

        <blockquote class="testimonial reveal-up reveal-delay-1">
          <p>"Really delicious meats and very friendly and helpful staff."</p>
          <footer>Local customer review</footer>
        </blockquote>

        <blockquote class="testimonial reveal-up reveal-delay-2">
          <p>"Finally had a Spearings pork pie and I'm happier than I have any right to be."</p>
          <footer>Local customer review</footer>
        </blockquote>
      </div>
    </section>

    <section class="section section-cream">
      <div class="container visit-grid">
        <div class="visit-card stack reveal-left">
          <p class="eyebrow">Visit The Shop</p>
          <h2>Find us at 12 Park Green, Macclesfield.</h2>
          <p>
            Pop in and see us - whether it's your weekly shop, a last-minute dinner decision,
            or you just want to browse what's on the counter. We're always happy to help.
          </p>
          <a href="/visit" class="card-link">Plan your visit</a>
        </div>

        <div class="visit-card detail-list reveal-right reveal-d1">
          <div>
            <strong>Address</strong>
            <span>12 Park Green, Macclesfield, Cheshire, SK11 7NA</span>
          </div>
          <div>
            <strong>Phone</strong>
            <span>01625 424395</span>
          </div>
          <div>
            <strong>Email</strong>
            <span>admin@spearings.co.uk</span>
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  .hero-brand-wrap {
    display: flex;
    justify-content: center;
  }

  .hero-brand-banner {
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    isolation: isolate;
    width: min(46rem, 94vw);
    margin: 0 auto clamp(2rem, 5vw, 3rem);
    padding: clamp(0.95rem, 2vw, 1.25rem) clamp(1rem, 2.8vw, 1.75rem);
    background: linear-gradient(180deg, rgba(255, 253, 247, 0.995), rgba(249, 243, 226, 0.98));
    box-shadow:
      0 0 0 7px rgba(255, 253, 247, 0.96),
      0 0 18px rgba(236, 202, 99, 0.14),
      0 0 38px rgba(236, 202, 99, 0.16),
      0 0 70px rgba(236, 202, 99, 0.12),
      0 22px 48px rgba(0, 0, 0, 0.24),
      inset 0 1px 0 rgba(255, 255, 255, 0.55);
    border-radius: var(--radius-xl);
  }

  .hero-brand-banner::before {
    content: '';
    position: absolute;
    inset: -2px;
    z-index: -2;
    border-radius: calc(var(--radius-xl) + 2px);
    background: transparent;
    box-shadow:
      0 0 24px rgba(236, 202, 99, 0.12),
      0 0 52px rgba(236, 202, 99, 0.12);
    opacity: 0;
    transform: scale(0.96);
    transition: opacity 0.9s ease, transform 0.9s ease;
    pointer-events: none;
  }

  .hero-brand-banner::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: -1;
    border-radius: var(--radius-xl);
    background: transparent;
    opacity: 0;
    transform: scale(0.98);
    transition: opacity 0.9s ease, transform 0.9s ease;
    pointer-events: none;
  }

  .hero-brand-banner.visible {
    animation: heroBannerSettle 1.05s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .hero-brand-banner.visible::before,
  .hero-brand-banner.visible::after {
    opacity: 1;
    transform: scale(1);
    animation: heroBannerGlow 5.5s ease-in-out infinite;
  }

  .hero-brand-banner img {
    display: block;
    width: 100%;
    height: auto;
    max-height: clamp(7rem, 14vw, 11rem);
    object-fit: contain;
  }

  .home-hero-copy {
    width: min(100%, 29rem);
    max-width: 29rem;
    justify-self: start;
    margin: 0;
  }

  .home-hero-copy h1 {
    width: 100%;
    max-width: 11.2ch;
    font-size: clamp(2.75rem, 4.4vw, 4.2rem);
    line-height: 1;
    text-wrap: balance;
  }

  .home-hero-copy .hero-title-main {
    display: block;
  }

  .home-hero-copy h1 em {
    display: block;
    margin-top: 0.12em;
    max-width: 8.8ch;
    font-size: 0.88em;
  }

  .home-hero-copy .hero-lead {
    max-width: 35rem;
    font-size: 1.18rem;
  }

  .home-hero-copy .badge-year {
    font-size: 1.12rem;
    letter-spacing: 0.11em;
  }

  .home-hero-copy .hero-badge > :last-child {
    font-size: 1.02rem;
  }

  .media-frame {
    border-radius: var(--radius-xl);
    overflow: hidden;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.12);
  }

  .media-frame img {
    border-radius: 0;
    display: block;
    width: 100%;
  }

  .media-frame.media-float {
    border-radius: var(--radius-md);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.15);
    border: 3px solid rgba(255, 255, 255, 0.3);
  }

  .media-badge {
    border-radius: var(--radius-md);
  }

  .hero-media.visible .hero-photo-main {
    animation: heroPhotoLift 1s cubic-bezier(0.22, 1, 0.36, 1) 0.12s both;
  }

  .hero-media.visible .hero-photo-float {
    animation: heroPhotoFloatIn 1.1s cubic-bezier(0.22, 1, 0.36, 1) 0.28s both;
  }

  .story-image-frame {
    border-radius: var(--radius-xl);
    overflow: hidden;
    box-shadow: 0 6px 24px rgba(0, 0, 0, 0.1);
  }

  .reveal-right.visible .story-image-frame {
    animation: storyPhotoLift 0.95s cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  .story-image-frame img {
    border-radius: 0;
    display: block;
    width: 100%;
  }

  .product-card {
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  .testimonial {
    border-radius: var(--radius-lg);
  }

  @media (max-width: 860px) {
    .home-hero-copy {
      width: 100%;
      max-width: none;
    }

    .home-hero-copy h1 {
      max-width: 11.5ch;
      font-size: clamp(2.35rem, 10vw, 3.3rem);
      line-height: 1.02;
    }

    .home-hero-copy h1 em {
      max-width: none;
    }

    .hero-brand-banner {
      width: min(100%, 32rem);
      margin-bottom: 1.75rem;
    }

    .hero-brand-banner::before {
      inset: -10px;
    }
  }

  @media (max-width: 560px) {
    .home-hero-copy h1 {
      max-width: none;
      font-size: clamp(2rem, 9.4vw, 2.75rem);
      line-height: 1.04;
    }

    .home-hero-copy .hero-title-main,
    .home-hero-copy h1 em {
      max-width: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-brand-banner.visible::before,
    .hero-brand-banner.visible::after,
    .hero-media.visible .hero-photo-main,
    .hero-media.visible .hero-photo-float,
    .reveal-right.visible .story-image-frame {
      animation: none !important;
    }
  }

  @keyframes heroBannerSettle {
    0% {
      transform: scale(0.94) translateY(12px);
      filter: saturate(0.92);
    }

    60% {
      transform: scale(1.015) translateY(0);
      filter: saturate(1.05);
    }

    100% {
      transform: scale(1) translateY(0);
      filter: saturate(1);
    }
  }

  @keyframes heroBannerGlow {
    0%,
    100% {
      opacity: 0.72;
      box-shadow:
        0 0 18px rgba(236, 202, 99, 0.1),
        0 0 42px rgba(236, 202, 99, 0.11);
    }

    50% {
      opacity: 1;
      box-shadow:
        0 0 24px rgba(236, 202, 99, 0.14),
        0 0 54px rgba(236, 202, 99, 0.14);
    }
  }

  @keyframes heroPhotoLift {
    0% {
      opacity: 0;
      transform: translateY(34px) scale(0.96);
    }

    100% {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  @keyframes heroPhotoFloatIn {
    0% {
      opacity: 0;
      transform: translate3d(-18px, 34px, 0) rotate(-3deg) scale(0.94);
    }

    100% {
      opacity: 1;
      transform: translate3d(0, 0, 0) rotate(0deg) scale(1);
    }
  }

  @keyframes storyPhotoLift {
    0% {
      opacity: 0;
      transform: translateY(24px) scale(0.97);
    }

    100% {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }
</style>
