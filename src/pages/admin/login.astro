---
import { validateCredentials, adminLoginHeaders, getAdminFromRequest } from '../../lib/admin-auth';

const admin = getAdminFromRequest(Astro.request);
if (admin) return Astro.redirect('/admin');

let error = '';

if (Astro.request.method === 'POST') {
  const form = await Astro.request.formData();
  const email = form.get('email')?.toString() ?? '';
  const password = form.get('password')?.toString() ?? '';

  if (validateCredentials(email, password)) {
    const headers = adminLoginHeaders(email);
    headers.set('Location', '/admin');
    return new Response(null, { status: 302, headers });
  }
  error = 'Invalid email or password';
}
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Login — Spearings Admin</title>
  <link
    href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&display=swap"
    rel="stylesheet"
  />
</head>
<body>
  <div class="login-page">
    <div class="login-card">
      <div class="login-header">
        <img src="/images/crest-logo-header-new.png" alt="" class="login-logo" />
        <h1>Spearings Admin</h1>
        <p>Sign in to manage orders, products, and settings.</p>
      </div>

      {error && <div class="login-error">{error}</div>}

      <form method="POST">
        <div class="login-field">
          <label for="email">Email</label>
          <input type="email" id="email" name="email" required autocomplete="email" />
        </div>
        <div class="login-field">
          <label for="password">Password</label>
          <input type="password" id="password" name="password" required />
        </div>
        <button type="submit" class="login-btn">Sign In</button>
      </form>

      <a href="/" class="login-back">← Back to website</a>
    </div>
  </div>
</body>
</html>

<style>
  * { box-sizing: border-box; }
  body {
    margin: 0;
    font-family: 'DM Sans', system-ui, sans-serif;
    background: #0e2318;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .login-page { padding: 1rem; width: 100%; max-width: 24rem; }

  .login-card {
    background: #fff;
    border-radius: 16px;
    padding: 2rem;
    box-shadow: 0 24px 60px rgba(0, 0, 0, 0.3);
  }

  .login-header {
    text-align: center;
    margin-bottom: 1.5rem;
  }

  .login-logo {
    width: 3.5rem;
    height: 3.5rem;
    border-radius: 12px;
    object-fit: contain;
    margin-bottom: 0.75rem;
  }

  .login-header h1 {
    margin: 0;
    font-size: 1.4rem;
    color: #0e2318;
  }

  .login-header p {
    margin: 0.35rem 0 0;
    font-size: 0.88rem;
    color: rgba(26, 26, 24, 0.55);
  }

  .login-error {
    padding: 0.65rem 0.85rem;
    border-radius: 8px;
    background: #fef2f2;
    color: #dc3545;
    font-size: 0.85rem;
    font-weight: 600;
    margin-bottom: 1rem;
    border: 1px solid rgba(220, 53, 69, 0.2);
  }

  .login-field {
    margin-bottom: 1rem;
  }

  .login-field label {
    display: block;
    margin-bottom: 0.3rem;
    font-size: 0.82rem;
    font-weight: 600;
    color: rgba(26, 26, 24, 0.65);
  }

  .login-field input {
    width: 100%;
    padding: 0.65rem 0.85rem;
    border: 1px solid rgba(26, 26, 24, 0.2);
    border-radius: 8px;
    font-family: inherit;
    font-size: 0.95rem;
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .login-field input:focus {
    outline: none;
    border-color: #c99a1a;
    box-shadow: 0 0 0 3px rgba(201, 154, 26, 0.15);
  }

  .login-btn {
    width: 100%;
    padding: 0.75rem;
    background: #0e2318;
    color: #f5edd8;
    border: none;
    border-radius: 8px;
    font-family: inherit;
    font-size: 0.95rem;
    font-weight: 700;
    cursor: pointer;
    transition: background 0.2s;
  }

  .login-btn:hover { background: #183622; }

  .login-back {
    display: block;
    text-align: center;
    margin-top: 1.25rem;
    font-size: 0.82rem;
    color: rgba(26, 26, 24, 0.45);
    text-decoration: none;
  }

  .login-back:hover { color: #0e2318; }
</style>
