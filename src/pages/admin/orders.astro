---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { getAdminFromRequest } from '../../lib/admin-auth';
import { supabaseAdmin } from '../../lib/supabase-server';

const admin = getAdminFromRequest(Astro.request);
if (!admin) return Astro.redirect('/admin/login');

const statusFilter = Astro.url.searchParams.get('status') ?? '';
const dateFilter = Astro.url.searchParams.get('date') ?? '';

let query = supabaseAdmin
  .from('orders')
  .select('id, reference, customer_name, customer_email, customer_phone, order_type, delivery_date, total, status, created_at, notes')
  .order('created_at', { ascending: false })
  .limit(100);

if (statusFilter) query = query.eq('status', statusFilter);
if (dateFilter) query = query.eq('delivery_date', dateFilter);

const { data: orders } = await query;
const orderList = orders ?? [];

const statuses = ['pending', 'confirmed', 'preparing', 'ready', 'collected', 'delivered', 'cancelled', 'refunded'];
---

<AdminLayout title="Orders" activeNav="orders">
  <div class="admin-toolbar">
    <form method="GET" class="admin-actions">
      <select name="status" class="admin-input" style="width:auto;" onchange="this.form.submit()">
        <option value="">All Statuses</option>
        {statuses.map((s) => (
          <option value={s} selected={statusFilter === s}>{s.charAt(0).toUpperCase() + s.slice(1)}</option>
        ))}
      </select>
      <input type="date" name="date" class="admin-input" style="width:auto;" value={dateFilter} onchange="this.form.submit()" />
      {(statusFilter || dateFilter) && (
        <a href="/admin/orders" class="admin-btn admin-btn-sm">Clear</a>
      )}
    </form>
    <span style="color: rgba(26,26,24,0.5); font-size: 0.82rem;">{orderList.length} order{orderList.length !== 1 ? 's' : ''}</span>
  </div>

  <div class="admin-card">
    {orderList.length === 0 ? (
      <div class="admin-empty">No orders found.</div>
    ) : (
      <table class="admin-table">
        <thead>
          <tr>
            <th>Ref</th>
            <th>Customer</th>
            <th>Type</th>
            <th>Date</th>
            <th>Total</th>
            <th>Status</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          {orderList.map((order: any) => (
            <tr data-order-id={order.id}>
              <td><strong>{order.reference}</strong></td>
              <td>
                <div>{order.customer_name}</div>
                <div style="font-size:0.78rem;color:rgba(26,26,24,0.5);">{order.customer_email}</div>
              </td>
              <td style="text-transform:capitalize;">{order.order_type}</td>
              <td>{new Date(order.delivery_date).toLocaleDateString('en-GB', { weekday: 'short', day: 'numeric', month: 'short' })}</td>
              <td>£{(order.total / 100).toFixed(2)}</td>
              <td><span class={`admin-badge ${order.status}`}>{order.status}</span></td>
              <td>
                <select class="admin-input admin-status-select" data-order-id={order.id} style="width:auto;font-size:0.8rem;padding:0.25rem 0.4rem;">
                  {statuses.map((s) => (
                    <option value={s} selected={order.status === s}>{s.charAt(0).toUpperCase() + s.slice(1)}</option>
                  ))}
                </select>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    )}
  </div>
</AdminLayout>

<script is:inline>
  document.querySelectorAll('.admin-status-select').forEach(function(sel) {
    sel.addEventListener('change', function() {
      var orderId = sel.dataset.orderId;
      var newStatus = sel.value;
      fetch('/api/admin/orders', {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: orderId, status: newStatus })
      }).then(function(r) {
        if (r.ok) {
          var badge = sel.closest('tr').querySelector('.admin-badge');
          badge.className = 'admin-badge ' + newStatus;
          badge.textContent = newStatus;
          showToast('Order updated');
        } else { showToast('Failed to update'); }
      });
    });
  });

  function showToast(msg) {
    var el = document.createElement('div');
    el.className = 'admin-toast';
    el.textContent = msg;
    document.body.appendChild(el);
    setTimeout(function() { el.remove(); }, 2500);
  }
</script>
