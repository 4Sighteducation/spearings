---
import AdminPublishSite from '../../components/admin/AdminPublishSite.astro';
import AdminLayout from '../../layouts/AdminLayout.astro';
import { getAdminFromRequest } from '../../lib/admin-auth';
import { supabaseAdmin } from '../../lib/supabase-server';

const admin = getAdminFromRequest(Astro.request);
if (!admin) return Astro.redirect('/admin/login');

const categoryFilter = Astro.url.searchParams.get('category') ?? '';
const viewParam = Astro.url.searchParams.get('view');
const viewMode: 'table' | 'cards' = viewParam === 'cards' ? 'cards' : 'table';

function adminProductsLink(overrides: Record<string, string | undefined>) {
  const u = new URL(Astro.url);
  for (const [k, val] of Object.entries(overrides)) {
    if (val === undefined || val === '') u.searchParams.delete(k);
    else u.searchParams.set(k, val);
  }
  return `${u.pathname}${u.search}`;
}

const [{ data: categories }, { data: subcats }, { data: imageRows }] = await Promise.all([
  supabaseAdmin.from('categories').select('id, slug, name').order('sort_order'),
  supabaseAdmin.from('subcategories').select('id, slug, name, category_id').order('name'),
  supabaseAdmin.from('product_images').select('product_id, local_path, source_url, sort_order'),
]);

let prodQuery = supabaseAdmin
  .from('products')
  .select(
    'id, slug, name, price, price_type, size, short_description, is_draft, is_archived, sort_order, category_id, subcategory_id, source_image_url, categories!inner(slug, name)',
  )
  .order('sort_order', { ascending: true })
  .order('name');
if (categoryFilter) {
  prodQuery = prodQuery.eq('categories.slug', categoryFilter);
}
const { data: rawProducts, error: productsError } = await prodQuery;

/** First image row per product (by sort_order) — matches storefront priority. */
const imageByProduct = new Map<string, { local_path: string | null; source_url: string | null }>();
for (const row of [...(imageRows ?? [])].sort((a: any, b: any) => (a.sort_order ?? 0) - (b.sort_order ?? 0))) {
  if (!imageByProduct.has(row.product_id)) {
    imageByProduct.set(row.product_id, { local_path: row.local_path, source_url: row.source_url });
  }
}

function adminProductImageUrl(
  p: { slug: string; source_image_url: string | null },
  img: { local_path: string | null; source_url: string | null } | null | undefined,
): string {
  if (img?.local_path) {
    const lp = img.local_path;
    return lp.startsWith('/') ? lp : `/${lp}`;
  }
  if (img?.source_url) return img.source_url;
  if (p.source_image_url) return p.source_image_url;
  return `/product-images/${p.slug}.jpg`;
}

const categoryById = new Map((categories ?? []).map((c: any) => [c.id, c]));
const subById = new Map((subcats ?? []).map((s: any) => [s.id, s]));

const productList = (rawProducts ?? [])
  .filter((p: any) => !p.is_archived)
  .map((p: any) => {
    const c = p.category_id ? categoryById.get(p.category_id) : undefined;
    const s = p.subcategory_id ? subById.get(p.subcategory_id) : undefined;
    const img = imageByProduct.get(p.id);
    return {
      ...p,
      categories: c ? { slug: c.slug, name: c.name } : null,
      subcategories: s ? { slug: s.slug, name: s.name } : null,
      _previewUrl: adminProductImageUrl(p, img),
    };
  });

const categoriesList = (categories ?? []).map((c: any) => ({
  id: c.id,
  slug: c.slug,
  name: c.name,
}));

const subcategoriesList = (subcats ?? []).map((s: any) => ({
  id: s.id,
  slug: s.slug,
  name: s.name,
  categoryId: s.category_id,
}));

const payload = {
  categories: categoriesList,
  subcategories: subcategoriesList,
};

const dataJson = JSON.stringify(payload).replace(/</g, '\\u003c');

const PRICE_TYPES = ['by_count', 'by_weight', 'other'];
---

<AdminLayout title="Products" activeNav="products">
  <div class="admin-toolbar products-view-toolbar">
    <div class="admin-actions" style="align-items: center; gap: 0.5rem; flex-wrap: wrap;">
      <span class="admin-muted" style="font-size: 0.85rem;">Layout:</span>
      <a
        href={adminProductsLink({ view: 'table' })}
        class:list={['admin-btn', 'admin-btn-sm', viewMode === 'table' && 'admin-btn-gold']}
        >Quick table</a>
      <a
        href={adminProductsLink({ view: 'cards' })}
        class:list={['admin-btn', 'admin-btn-sm', viewMode === 'cards' && 'admin-btn-gold']}
        >Full editor</a>
    </div>
    <p class="admin-muted" style="margin: 0; font-size: 0.82rem; max-width: 44rem;">
      <strong>Quick table</strong> — fast price edits. <strong>Full editor</strong> — images, categories, descriptions,
      and CSV tools.
    </p>
  </div>

  <AdminPublishSite cardStyle="margin-bottom: 1.5rem;" />

  {productsError && (
    <div class="admin-card products-error-banner" role="alert">
      <strong>Could not load products.</strong> {productsError.message} Check Supabase credentials and that the
      <code>products</code> table exists.
    </div>
  )}

  {viewMode === 'cards' && (
    <>
      <p class="products-lead">
        Search and edit products inline. Use checkboxes to export a <strong>prefilled</strong> CSV (includes slugs and
        category codes) for bulk edits, then upload it again. The blank template lists every column the importer expects.
      </p>
      <p class="products-save-reminder">
        Each product has its own <strong>Save</strong> button. Changes are <strong>not</strong> stored until you click Save
        on that card — unsaved rows are highlighted in red.
      </p>

      <div class="admin-toolbar products-toolbar">
    <div class="admin-actions products-toolbar-left">
      <input
        type="search"
        class="admin-input products-search"
        id="productSearch"
        placeholder="Search name, slug, description…"
        autocomplete="off"
      />
      <select class="admin-input" id="categoryFilter" style="width: auto; min-width: 11rem">
        <option value="">All categories</option>
        {categoriesList.map((c) => (
          <option value={c.slug}>{c.name}</option>
        ))}
      </select>
      <span class="products-count" id="productsCount"></span>
    </div>
    <div class="admin-actions">
      <button type="button" class="admin-btn admin-btn-sm" id="selectVisibleBtn">Select visible</button>
      <button type="button" class="admin-btn admin-btn-sm" id="clearSelectionBtn">Clear selection</button>
    </div>
    <div class="admin-actions products-toolbar-csv">
      <button type="button" class="admin-btn" id="downloadVisibleCsvBtn" title="Current table rows (respects search & category)">
        Download visible CSV
      </button>
      <button type="button" class="admin-btn" id="downloadSelectedCsvBtn">Download selected CSV</button>
      <button type="button" class="admin-btn" id="downloadAllCsvBtn">Download all products CSV</button>
      <button type="button" class="admin-btn" id="downloadTemplateBtn">Blank template</button>
      <label class="admin-btn admin-btn-gold">
        Upload CSV
        <input type="file" accept=".csv,text/csv" id="uploadCsvInput" hidden />
      </label>
    </div>
  </div>

  <div id="uploadStatus" class="products-upload-status" hidden></div>

  <div class="admin-card products-card">
    {!productsError && productList.length === 0 ? (
      <div class="admin-empty">No products found. Add products in the database or upload a CSV.</div>
    ) : productsError ? (
      <div class="admin-empty">Fix the error above, then refresh.</div>
    ) : (
      <div class="products-list-hint">
        <label class="products-select-all-head">
          <input type="checkbox" id="selectAllCheckbox" title="Select all visible" />
          Select all visible
        </label>
      </div>
      <div class="products-card-list" id="productTableBody">
        {productList.map((p: any) => {
          const catSlug = p.categories?.slug ?? '';
          const searchBlob = [p.name, p.slug, p.short_description, p.categories?.name, p.subcategories?.name]
            .filter(Boolean)
            .join(' ')
            .toLowerCase()
            .replace(/\s+/g, ' ')
            .trim();
          const imgUrl = p.source_image_url ?? '';
          return (
            <article
              class="product-row product-card"
              data-product-id={p.id}
              data-category-slug={catSlug}
              data-search={searchBlob}
              data-preview-fallback={p._previewUrl}
            >
              <p class="product-unsaved-banner" role="status" aria-live="polite" hidden>
                Unsaved changes — click <strong>Save</strong> on this card or your edits will not appear on the website.
              </p>
              <div class="product-card-head">
                <label class="product-card-check">
                  <input type="checkbox" class="row-select" data-product-id={p.id} />
                </label>
                <div class="product-card-thumb-wrap">
                  <img
                    class="product-thumb-img"
                    src={p._previewUrl}
                    alt=""
                    width="88"
                    height="88"
                    loading="lazy"
                    decoding="async"
                    referrerpolicy="no-referrer"
                  />
                </div>
                <div class="product-card-head-main">
                  <label class="product-field-label">
                    Name
                    <input
                      type="text"
                      class="admin-input input-name"
                      value={p.name}
                      data-original={p.name}
                      data-product-id={p.id}
                    />
                  </label>
                  <p class="product-slug-line">
                    Slug: <code class="product-slug-text">{p.slug}</code>
                  </p>
                </div>
                <div class="product-card-head-actions">
                  <button type="button" class="admin-btn admin-btn-sm save-row-btn" data-product-id={p.id} disabled>
                    Save
                  </button>
                </div>
              </div>

              <div class="product-card-grid">
                <label class="product-field-label">
                  Category
                  <select class="admin-input input-category" data-product-id={p.id} data-original={p.category_id ?? ''}>
                    <option value="">—</option>
                    {categoriesList.map((c) => (
                      <option value={c.id} selected={p.category_id === c.id}>
                        {c.name}
                      </option>
                    ))}
                  </select>
                </label>
                <label class="product-field-label">
                  Subcategory
                  <select class="admin-input input-subcategory" data-product-id={p.id} data-original={p.subcategory_id ?? ''}>
                    <option value="">—</option>
                    {subcategoriesList
                      .filter((s) => s.categoryId === p.category_id)
                      .map((s) => (
                        <option value={s.id} selected={p.subcategory_id === s.id}>
                          {s.name}
                        </option>
                      ))}
                  </select>
                </label>
                <label class="product-field-label">
                  Size
                  <input
                    type="text"
                    class="admin-input input-size"
                    value={p.size ?? ''}
                    data-original={p.size ?? ''}
                    data-product-id={p.id}
                  />
                </label>
                <label class="product-field-label">
                  Price (£)
                  <input
                    type="number"
                    step="0.01"
                    class="admin-input input-price"
                    value={p.price ?? ''}
                    data-original={p.price ?? ''}
                    data-product-id={p.id}
                  />
                </label>
                <label class="product-field-label">
                  Price type
                  <select class="admin-input input-price-type" data-product-id={p.id} data-original={p.price_type ?? 'by_count'}>
                    {(() => {
                      const cur = p.price_type || 'by_count';
                      const opts = [...PRICE_TYPES];
                      if (cur && !opts.includes(cur)) opts.unshift(cur);
                      return opts.map((pt) => (
                        <option value={pt} selected={cur === pt}>
                          {pt}
                        </option>
                      ));
                    })()}
                  </select>
                </label>
                <div class="product-field-label product-field-draft">
                  <span class="product-field-label-text">Status</span>
                  <label class="products-draft-label">
                    <input type="checkbox" class="input-draft" checked={p.is_draft} data-original={p.is_draft ? '1' : '0'} data-product-id={p.id} />
                    Draft
                  </label>
                </div>
              </div>

              <label class="product-field-label product-field-block">
                Short description
                <textarea
                  class="admin-input input-desc"
                  rows="3"
                  data-original={p.short_description ?? ''}
                  data-product-id={p.id}
                >
                  {p.short_description ?? ''}
                </textarea>
              </label>

              <div class="product-card-image-block">
                <label class="product-field-label product-field-block">
                  Image URL
                  <input
                    type="url"
                    class="admin-input input-image-url"
                    placeholder="https://…"
                    value={imgUrl}
                    data-original={imgUrl}
                    data-product-id={p.id}
                    autocomplete="off"
                  />
                </label>
                <p class="product-image-hint">
                  Shown on the shop after Save. The preview uses the same order as the site: gallery file path, then
                  gallery URL, then this field.
                </p>
              </div>
            </article>
          );
        })}
      </div>
    )}
  </div>
    </>
  )}

  {viewMode === 'table' && (
    <>
      <div class="admin-toolbar">
        <div class="admin-actions">
          <form method="GET" class="products-table-filter-form" style="display: flex; gap: 0.5rem; align-items: center;">
            <select name="category" class="admin-input" style="width: auto;" onchange="this.form.submit()">
              <option value="">All Categories</option>
              {categoriesList.map((c: any) => (
                <option value={c.slug} selected={categoryFilter === c.slug}>
                  {c.name}
                </option>
              ))}
            </select>
            {categoryFilter && (
              <a href={adminProductsLink({ category: '' })} class="admin-btn admin-btn-sm">
                Clear
              </a>
            )}
          </form>
        </div>
        <div class="admin-actions">
          <button type="button" class="admin-btn" id="downloadCsvBtn">Download CSV</button>
          <label class="admin-btn admin-btn-gold">
            Upload CSV
            <input type="file" accept=".csv,text/csv" id="uploadCsvInputTable" hidden />
          </label>
          <button type="button" class="admin-btn" id="downloadTemplateBtnTable">Template</button>
        </div>
      </div>

      <div id="uploadStatusTable" class="products-upload-status" hidden></div>

      <div class="admin-card">
        {productsError ? (
          <div class="admin-empty">Fix the error above, then refresh.</div>
        ) : productList.length === 0 ? (
          <div class="admin-empty">No products found. Upload a CSV or seed the database.</div>
        ) : (
          <table class="admin-table">
            <thead>
              <tr>
                <th>Product</th>
                <th>Category</th>
                <th>Size</th>
                <th>Price</th>
                <th>Type</th>
                <th>Status</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody id="productTableBody">
              {productList.map((p: any) => (
                <tr data-product-id={p.id}>
                  <td>
                    <strong>{p.name}</strong>
                    <div style="font-size: 0.75rem; color: rgba(26, 26, 24, 0.4);">{p.slug}</div>
                  </td>
                  <td>{p.categories?.name ?? '—'}</td>
                  <td>{p.size ?? '—'}</td>
                  <td>
                    <input
                      type="number"
                      step="0.01"
                      class="admin-input price-input"
                      style="width: 5.5rem;"
                      value={p.price ?? ''}
                      data-product-id={p.id}
                      data-original={p.price ?? ''}
                    />
                  </td>
                  <td style="font-size: 0.8rem;">{p.price_type}</td>
                  <td>
                    {p.is_draft ? (
                      <span class="admin-badge pending">Draft</span>
                    ) : (
                      <span class="admin-badge confirmed">Active</span>
                    )}
                  </td>
                  <td>
                    <button type="button" class="admin-btn admin-btn-sm save-price-btn" data-product-id={p.id} disabled>
                      Save
                    </button>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        )}
      </div>
    </>
  )}

  {viewMode === 'cards' && (
    <>
      <script type="application/json" id="products-admin-data" set:html={dataJson} />

      <script is:inline>
    (function () {
      /* Keep in sync with src/lib/admin-publish-pending.ts */
      var PUBLISH_PENDING_KEY = 'spearings_publish_pending_products';
      var PUBLISH_PENDING_EVENT = 'spearings:publishPendingChanged';

      var dataEl = document.getElementById('products-admin-data');
      if (!dataEl) return;
      var DATA = JSON.parse(dataEl.textContent || '{}');
      var CATEGORIES = DATA.categories || [];
      var SUBCATEGORIES = DATA.subcategories || [];

      function subOptionsForCategory(categoryId) {
        return SUBCATEGORIES.filter(function (s) {
          return s.categoryId === categoryId;
        });
      }

      function refillSubcategorySelect(selectEl, categoryId, currentSubId) {
        var subs = subOptionsForCategory(categoryId);
        selectEl.innerHTML = '<option value="">—</option>';
        subs.forEach(function (s) {
          var opt = document.createElement('option');
          opt.value = s.id;
          opt.textContent = s.name;
          if (currentSubId && s.id === currentSubId) opt.selected = true;
          selectEl.appendChild(opt);
        });
      }

      document.querySelectorAll('.input-category').forEach(function (sel) {
        sel.addEventListener('change', function () {
          var id = sel.dataset.productId;
          var sub = document.querySelector('.input-subcategory[data-product-id="' + id + '"]');
          if (!sub) return;
          var catId = sel.value || '';
          var subs = subOptionsForCategory(catId);
          var keep = sub.value;
          var stillValid = subs.some(function (s) {
            return s.id === keep;
          });
          refillSubcategorySelect(sub, catId, stillValid ? keep : '');
          markDirty(id);
        });
      });

      function getRow(id) {
        return document.querySelector('article.product-row[data-product-id="' + id + '"]');
      }

      function updateRowUnsavedUi(row) {
        if (!row) return;
        var dirty = isRowDirty(row);
        row.classList.toggle('product-row--unsaved', dirty);
        var banner = row.querySelector('.product-unsaved-banner');
        if (banner) {
          if (dirty) {
            banner.removeAttribute('hidden');
          } else {
            banner.setAttribute('hidden', '');
          }
        }
      }

      function markDirty(id) {
        var row = getRow(id);
        if (!row) return;
        var btn = row.querySelector('.save-row-btn');
        if (!btn) return;
        var dirty = isRowDirty(row);
        btn.disabled = !dirty;
        updateRowUnsavedUi(row);
      }

      function isRowDirty(row) {
        var name = row.querySelector('.input-name');
        var cat = row.querySelector('.input-category');
        var sub = row.querySelector('.input-subcategory');
        var size = row.querySelector('.input-size');
        var price = row.querySelector('.input-price');
        var pt = row.querySelector('.input-price-type');
        var desc = row.querySelector('.input-desc');
        var draft = row.querySelector('.input-draft');
        var imgUrl = row.querySelector('.input-image-url');

        if (name.value !== name.dataset.original) return true;
        if ((cat.value || '') !== (cat.dataset.original || '')) return true;
        if ((sub.value || '') !== (sub.dataset.original || '')) return true;
        if ((size.value || '') !== (size.dataset.original || '')) return true;

        var origRaw = price.dataset.original;
        var curRaw = price.value.trim();
        if (origRaw === '' || origRaw === undefined) {
          if (curRaw !== '') return true;
        } else {
          var pOrig = parseFloat(origRaw);
          var pCur = parseFloat(curRaw);
          if (curRaw === '' || isNaN(pCur) || pCur !== pOrig) return true;
        }

        if ((pt.value || '') !== (pt.dataset.original || '')) return true;
        if ((desc.value || '') !== (desc.dataset.original || '')) return true;
        var dNow = draft.checked ? '1' : '0';
        if (dNow !== draft.dataset.original) return true;
        if (imgUrl && (imgUrl.value || '') !== (imgUrl.dataset.original || '')) return true;
        return false;
      }

      function wireField(el, id) {
        el.addEventListener('input', function () {
          markDirty(id);
        });
        el.addEventListener('change', function () {
          markDirty(id);
        });
      }

      document.querySelectorAll('.product-row').forEach(function (row) {
        var id = row.dataset.productId;
        ['.input-name', '.input-size', '.input-price', '.input-desc', '.input-draft', '.input-image-url'].forEach(function (sel) {
          var el = row.querySelector(sel);
          if (el) wireField(el, id);
        });
        ['.input-category', '.input-subcategory', '.input-price-type'].forEach(function (sel) {
          var el = row.querySelector(sel);
          if (el)
            el.addEventListener('change', function () {
              markDirty(id);
            });
        });

        row.querySelector('.save-row-btn').addEventListener('click', function () {
          var btn = row.querySelector('.save-row-btn');
          var name = row.querySelector('.input-name');
          var cat = row.querySelector('.input-category');
          var sub = row.querySelector('.input-subcategory');
          var size = row.querySelector('.input-size');
          var price = row.querySelector('.input-price');
          var pt = row.querySelector('.input-price-type');
          var desc = row.querySelector('.input-desc');
          var draft = row.querySelector('.input-draft');
          var imgField = row.querySelector('.input-image-url');

          var body = {
            id: id,
            name: name.value,
            category_id: cat.value || null,
            subcategory_id: sub.value || null,
            size: size.value || null,
            short_description: desc.value || null,
            price_type: pt.value,
            is_draft: draft.checked,
            source_image_url: imgField ? imgField.value.trim() || null : null,
          };
          if (price.value !== '') {
            var pr = parseFloat(price.value);
            if (!isNaN(pr)) body.price = pr;
          } else {
            body.price = null;
          }

          btn.disabled = true;
          btn.textContent = '…';
          fetch('/api/admin/products', {
            method: 'PATCH',
            credentials: 'same-origin',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(body),
          })
            .then(function (r) {
              return r.text().then(function (text) {
                var j = {};
                try {
                  j = text ? JSON.parse(text) : {};
                } catch (e) {
                  j = { error: text ? text.slice(0, 200) : 'Bad response' };
                }
                return { ok: r.ok, j: j, status: r.status };
              });
            })
            .then(function (_ref) {
              var ok = _ref.ok;
              var j = _ref.j;
              var status = _ref.status;
              btn.textContent = 'Save';
              if (ok) {
                name.dataset.original = name.value;
                cat.dataset.original = cat.value || '';
                sub.dataset.original = sub.value || '';
                size.dataset.original = size.value || '';
                price.dataset.original = price.value;
                pt.dataset.original = pt.value;
                desc.dataset.original = desc.value || '';
                draft.dataset.original = draft.checked ? '1' : '0';
                if (imgField) {
                  imgField.dataset.original = imgField.value || '';
                  var thumb = row.querySelector('.product-thumb-img');
                  if (thumb) {
                    var u = imgField.value.trim();
                    if (u) {
                      thumb.src = u + (u.indexOf('?') === -1 ? '?' : '&') + 't=' + Date.now();
                    } else {
                      thumb.src = row.dataset.previewFallback || thumb.src;
                    }
                  }
                }
                try {
                  localStorage.setItem(PUBLISH_PENDING_KEY, '1');
                } catch (e) {}
                window.dispatchEvent(new CustomEvent(PUBLISH_PENDING_EVENT));
                markDirty(id);
                showToast('Saved');
              } else {
                btn.disabled = false;
                showToast(j.error || 'Save failed (' + status + ')');
              }
            })
            .catch(function (err) {
              btn.textContent = 'Save';
              btn.disabled = false;
              showToast('Network error: ' + (err && err.message ? err.message : 'Save failed'));
            });
        });
      });

      function applyFilters() {
        var q = (document.getElementById('productSearch').value || '').trim().toLowerCase();
        var cat = document.getElementById('categoryFilter').value || '';
        var rows = document.querySelectorAll('.product-row');
        var n = 0;
        rows.forEach(function (row) {
          var matchCat = !cat || row.dataset.categorySlug === cat;
          var blob = row.dataset.search || '';
          var matchQ = !q || blob.indexOf(q) !== -1;
          var show = matchCat && matchQ;
          row.style.display = show ? '' : 'none';
          if (show) n++;
        });
        var total = rows.length;
        document.getElementById('productsCount').textContent = n === total ? total + ' products' : n + ' of ' + total + ' shown';
      }

      document.getElementById('productSearch').addEventListener('input', applyFilters);
      document.getElementById('categoryFilter').addEventListener('change', applyFilters);
      applyFilters();

      window.addEventListener('beforeunload', function (e) {
        var any = document.querySelector('.product-row--unsaved');
        if (any) {
          e.preventDefault();
          e.returnValue = '';
        }
      });

      document.getElementById('selectAllCheckbox').addEventListener('change', function () {
        var on = this.checked;
        document.querySelectorAll('.product-row').forEach(function (row) {
          if (row.style.display === 'none') return;
          var cb = row.querySelector('.row-select');
          if (cb) cb.checked = on;
        });
      });

      document.getElementById('selectVisibleBtn').addEventListener('click', function () {
        document.querySelectorAll('.product-row').forEach(function (row) {
          if (row.style.display === 'none') return;
          var cb = row.querySelector('.row-select');
          if (cb) cb.checked = true;
        });
      });

      document.getElementById('clearSelectionBtn').addEventListener('click', function () {
        document.querySelectorAll('.row-select').forEach(function (cb) {
          cb.checked = false;
        });
        var all = document.getElementById('selectAllCheckbox');
        if (all) all.checked = false;
      });

      function slugFromRow(row) {
        var code = row.querySelector('.product-slug-text');
        return code ? code.textContent.trim() : '';
      }

      function categorySlugFromSelect(selectEl) {
        var opt = selectEl.options[selectEl.selectedIndex];
        if (!opt || !opt.value) return '';
        var id = opt.value;
        var c = CATEGORIES.find(function (x) {
          return x.id === id;
        });
        return c ? c.slug : '';
      }

      function subSlugFromSelect(selectEl) {
        var opt = selectEl.options[selectEl.selectedIndex];
        if (!opt || !opt.value) return '';
        var id = opt.value;
        var s = SUBCATEGORIES.find(function (x) {
          return x.id === id;
        });
        return s ? s.slug : '';
      }

      function rowToCsvLine(row) {
        var id = row.dataset.productId;
        var name = row.querySelector('.input-name');
        var cat = row.querySelector('.input-category');
        var sub = row.querySelector('.input-subcategory');
        var size = row.querySelector('.input-size');
        var price = row.querySelector('.input-price');
        var pt = row.querySelector('.input-price-type');
        var desc = row.querySelector('.input-desc');
        var draft = row.querySelector('.input-draft');
        return [
          slugFromRow(row),
          name.value,
          categorySlugFromSelect(cat),
          subSlugFromSelect(sub),
          size.value || '',
          price.value || '',
          pt.value,
          desc.value || '',
          draft.checked ? 'true' : 'false',
        ];
      }

      var CSV_HEADERS = ['slug', 'name', 'category', 'subcategory', 'size', 'price', 'price_type', 'short_description', 'is_draft'];

      function csvEscape(cell) {
        var s = cell === null || cell === undefined ? '' : String(cell);
        return '"' + s.replace(/"/g, '""') + '"';
      }

      function downloadCsv(rows, filename) {
        var csv = rows
          .map(function (r) {
            return r.map(csvEscape).join(',');
          })
          .join('\r\n');
        var blob = new Blob([csv], { type: 'text/csv;charset=utf-8' });
        var a = document.createElement('a');
        a.href = URL.createObjectURL(blob);
        a.download = filename;
        a.click();
        URL.revokeObjectURL(a.href);
      }

      document.getElementById('downloadVisibleCsvBtn').addEventListener('click', function () {
        var rows = [CSV_HEADERS];
        document.querySelectorAll('.product-row').forEach(function (row) {
          if (row.style.display === 'none') return;
          rows.push(rowToCsvLine(row));
        });
        downloadCsv(rows, 'spearings-products-visible.csv');
      });

      document.getElementById('downloadSelectedCsvBtn').addEventListener('click', function () {
        var rows = [CSV_HEADERS];
        document.querySelectorAll('.row-select:checked').forEach(function (cb) {
          var row = cb.closest('.product-row');
          if (row) rows.push(rowToCsvLine(row));
        });
        if (rows.length < 2) {
          showToast('Select at least one product');
          return;
        }
        downloadCsv(rows, 'spearings-products-selected.csv');
      });

      document.getElementById('downloadAllCsvBtn').addEventListener('click', function () {
        var rows = [CSV_HEADERS];
        document.querySelectorAll('.product-row').forEach(function (row) {
          rows.push(rowToCsvLine(row));
        });
        downloadCsv(rows, 'spearings-products-all.csv');
      });

      document.getElementById('downloadTemplateBtn').addEventListener('click', function () {
        var rows = [
          CSV_HEADERS,
          [
            'beef-pie-small',
            'Beef Pie — Small',
            'pies',
            '',
            'Small',
            '2.30',
            'by_count',
            'Example short description',
            'false',
          ],
        ];
        downloadCsv(rows, 'spearings-products-template.csv');
      });

      document.getElementById('uploadCsvInput').addEventListener('change', function (e) {
        var file = e.target.files[0];
        if (!file) return;
        var reader = new FileReader();
        reader.onload = function () {
          var text = reader.result;
          fetch('/api/admin/products/csv', {
            method: 'POST',
            headers: { 'Content-Type': 'text/csv' },
            body: text,
          })
            .then(function (r) {
              return r.json();
            })
            .then(function (data) {
              if (data.ok) {
                try {
                  localStorage.setItem(PUBLISH_PENDING_KEY, '1');
                } catch (e) {}
                var msg = 'Updated ' + data.updated + ', created ' + data.created;
                if (data.errors && data.errors.length) msg += ' (' + data.errors.length + ' row warnings)';
                showToast(msg);
                setTimeout(function () {
                  location.reload();
                }, 1200);
              } else {
                showToast('Error: ' + (data.error || 'Upload failed'));
              }
            })
            .catch(function () {
              showToast('Upload failed');
            });
        };
        reader.readAsText(file);
        e.target.value = '';
      });

      function showToast(msg) {
        var el = document.createElement('div');
        el.className = 'admin-toast';
        el.textContent = msg;
        document.body.appendChild(el);
        setTimeout(function () {
          el.remove();
        }, 2800);
      }
    })();
  </script>
