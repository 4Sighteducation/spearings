---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { getAdminFromRequest } from '../../lib/admin-auth';
import { supabaseAdmin } from '../../lib/supabase-server';

const admin = getAdminFromRequest(Astro.request);
if (!admin) return Astro.redirect('/admin/login');

const categoryFilter = Astro.url.searchParams.get('category') ?? '';

let prodQuery = supabaseAdmin
  .from('products')
  .select(`
    id, slug, name, price, price_type, size, short_description, is_draft, is_archived, sort_order,
    categories!inner(slug, name),
    subcategories(slug, name)
  `)
  .order('name');

if (categoryFilter) {
  prodQuery = prodQuery.eq('categories.slug', categoryFilter);
}

const [{ data: products }, { data: categories }] = await Promise.all([
  prodQuery,
  supabaseAdmin.from('categories').select('slug, name').order('sort_order'),
]);

const productList = (products ?? []).filter((p: any) => !p.is_archived);
---

<AdminLayout title="Products" activeNav="products">
  <div class="admin-toolbar">
    <div class="admin-actions">
      <form method="GET" style="display:flex;gap:0.5rem;">
        <select name="category" class="admin-input" style="width:auto;" onchange="this.form.submit()">
          <option value="">All Categories</option>
          {(categories ?? []).map((c: any) => (
            <option value={c.slug} selected={categoryFilter === c.slug}>{c.name}</option>
          ))}
        </select>
        {categoryFilter && <a href="/admin/products" class="admin-btn admin-btn-sm">Clear</a>}
      </form>
    </div>
    <div class="admin-actions">
      <button class="admin-btn" id="downloadCsvBtn">Download CSV</button>
      <label class="admin-btn admin-btn-gold">
        Upload CSV
        <input type="file" accept=".csv" id="uploadCsvInput" hidden />
      </label>
      <button class="admin-btn" id="downloadTemplateBtn">Template</button>
    </div>
  </div>

  <div id="uploadStatus" hidden></div>

  <div class="admin-card">
    {productList.length === 0 ? (
      <div class="admin-empty">
        No products found. Upload a CSV or seed the database.
      </div>
    ) : (
      <table class="admin-table">
        <thead>
          <tr>
            <th>Product</th>
            <th>Category</th>
            <th>Size</th>
            <th>Price</th>
            <th>Type</th>
            <th>Status</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody id="productTableBody">
          {productList.map((p: any) => (
            <tr data-product-id={p.id}>
              <td>
                <strong>{p.name}</strong>
                <div style="font-size:0.75rem;color:rgba(26,26,24,0.4);">{p.slug}</div>
              </td>
              <td>{p.categories?.name ?? '—'}</td>
              <td>{p.size ?? '—'}</td>
              <td>
                <input
                  type="number"
                  step="0.01"
                  class="admin-input price-input"
                  style="width:5.5rem;"
                  value={p.price ?? ''}
                  data-product-id={p.id}
                  data-original={p.price ?? ''}
                />
              </td>
              <td style="font-size:0.8rem;">{p.price_type}</td>
              <td>
                {p.is_draft
                  ? <span class="admin-badge pending">Draft</span>
                  : <span class="admin-badge confirmed">Active</span>
                }
              </td>
              <td>
                <button class="admin-btn admin-btn-sm save-price-btn" data-product-id={p.id} disabled>Save</button>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    )}
  </div>
</AdminLayout>

<script is:inline>
  // Inline editing
  document.querySelectorAll('.price-input').forEach(function(input) {
    input.addEventListener('input', function() {
      var btn = document.querySelector('.save-price-btn[data-product-id="' + input.dataset.productId + '"]');
      btn.disabled = input.value === input.dataset.original;
    });

    input.addEventListener('keydown', function(e) {
      if (e.key === 'Enter') {
        var btn = document.querySelector('.save-price-btn[data-product-id="' + input.dataset.productId + '"]');
        if (!btn.disabled) btn.click();
      }
    });
  });

  document.querySelectorAll('.save-price-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var id = btn.dataset.productId;
      var input = document.querySelector('.price-input[data-product-id="' + id + '"]');
      var price = parseFloat(input.value);
      if (isNaN(price)) return;

      btn.textContent = '...';
      fetch('/api/admin/products', {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: id, price: price })
      }).then(function(r) {
        if (r.ok) {
          input.dataset.original = input.value;
          btn.disabled = true;
          btn.textContent = 'Save';
          showToast('Price updated');
        } else {
          btn.textContent = 'Save';
          showToast('Failed to update');
        }
      });
    });
  });

  // CSV Download
  document.getElementById('downloadCsvBtn').addEventListener('click', function() {
    var rows = [['slug', 'name', 'category', 'size', 'price', 'price_type', 'short_description']];
    document.querySelectorAll('#productTableBody tr').forEach(function(tr) {
      var slug = tr.querySelector('td:first-child div').textContent;
      var name = tr.querySelector('td:first-child strong').textContent;
      var category = tr.querySelector('td:nth-child(2)').textContent.trim();
      var size = tr.querySelector('td:nth-child(3)').textContent.trim();
      var price = tr.querySelector('.price-input').value;
      var type = tr.querySelector('td:nth-child(5)').textContent.trim();
      rows.push([slug, name, category, size, price, type, '']);
    });
    downloadCsv(rows, 'spearings-products.csv');
  });

  // Template Download
  document.getElementById('downloadTemplateBtn').addEventListener('click', function() {
    var rows = [
      ['slug', 'name', 'category', 'size', 'price', 'price_type', 'short_description'],
      ['beef-pie-small', 'Beef Pie', 'pies', 'Small', '2.30', 'by_count', 'A classic beef pie.'],
    ];
    downloadCsv(rows, 'spearings-products-template.csv');
  });

  function downloadCsv(rows, filename) {
    var csv = rows.map(function(r) {
      return r.map(function(c) { return '"' + String(c).replace(/"/g, '""') + '"'; }).join(',');
    }).join('\n');
    var blob = new Blob([csv], { type: 'text/csv' });
    var a = document.createElement('a');
    a.href = URL.createObjectURL(blob);
    a.download = filename;
    a.click();
  }

  // CSV Upload
  document.getElementById('uploadCsvInput').addEventListener('change', function(e) {
    var file = e.target.files[0];
    if (!file) return;

    var reader = new FileReader();
    reader.onload = function() {
      var text = reader.result;
      fetch('/api/admin/products/csv', {
        method: 'POST',
        headers: { 'Content-Type': 'text/csv' },
        body: text,
      }).then(function(r) { return r.json(); }).then(function(data) {
        if (data.ok) {
          showToast('Updated ' + data.updated + ' products, created ' + data.created + ' new');
          setTimeout(function() { location.reload(); }, 1500);
        } else {
          showToast('Error: ' + (data.error || 'Upload failed'));
        }
      }).catch(function() {
        showToast('Upload failed');
      });
    };
    reader.readAsText(file);
    e.target.value = '';
  });

  function showToast(msg) {
    var el = document.createElement('div');
    el.className = 'admin-toast';
    el.textContent = msg;
    document.body.appendChild(el);
    setTimeout(function() { el.remove(); }, 2500);
  }
</script>
