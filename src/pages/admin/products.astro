  {viewMode === 'table' && (
    <script is:inline>
      /* Keep in sync with src/lib/admin-publish-pending.ts and the full editor script */
      var PUBLISH_PENDING_KEY = 'spearings_publish_pending_products';
      var PUBLISH_PENDING_EVENT = 'spearings:publishPendingChanged';

      function markPublishPending() {
        try {
          localStorage.setItem(PUBLISH_PENDING_KEY, '1');
        } catch (e) {}
        window.dispatchEvent(new CustomEvent(PUBLISH_PENDING_EVENT));
      }

      document.querySelectorAll('.price-input').forEach(function (input) {
        input.addEventListener('input', function () {
          var btn = document.querySelector('.save-price-btn[data-product-id="' + input.dataset.productId + '"]');
          if (!btn) return;
          btn.disabled = input.value === input.dataset.original;
        });

        input.addEventListener('keydown', function (e) {
          if (e.key === 'Enter') {
            var b = document.querySelector('.save-price-btn[data-product-id="' + input.dataset.productId + '"]');
            if (b && !b.disabled) b.click();
          }
        });
      });

      document.querySelectorAll('.save-price-btn').forEach(function (btn) {
        btn.addEventListener('click', function () {
          var id = btn.dataset.productId;
          var input = document.querySelector('.price-input[data-product-id="' + id + '"]');
          var price = parseFloat(input.value);
          if (isNaN(price)) return;

          btn.textContent = '...';
          fetch('/api/admin/products', {
            method: 'PATCH',
            credentials: 'same-origin',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ id: id, price: price }),
          })
            .then(function (r) {
              if (r.ok) {
                input.dataset.original = input.value;
                btn.disabled = true;
                btn.textContent = 'Save';
                markPublishPending();
                showToastTable('Price updated');
              } else {
                btn.textContent = 'Save';
                showToastTable('Failed to update');
              }
            })
            .catch(function () {
              btn.textContent = 'Save';
              showToastTable('Failed to update');
            });
        });
      });

      document.getElementById('downloadCsvBtn').addEventListener('click', function () {
        var rows = [['slug', 'name', 'category', 'size', 'price', 'price_type', 'short_description']];
        document.querySelectorAll('#productTableBody tr').forEach(function (tr) {
          var slug = tr.querySelector('td:first-child div').textContent;
          var name = tr.querySelector('td:first-child strong').textContent;
          var category = tr.querySelector('td:nth-child(2)').textContent.trim();
          var size = tr.querySelector('td:nth-child(3)').textContent.trim();
          var price = tr.querySelector('.price-input').value;
          var type = tr.querySelector('td:nth-child(5)').textContent.trim();
          rows.push([slug, name, category, size, price, type, '']);
        });
        downloadCsvTable(rows, 'spearings-products.csv');
      });

      document.getElementById('downloadTemplateBtnTable').addEventListener('click', function () {
        var rows = [
          ['slug', 'name', 'category', 'size', 'price', 'price_type', 'short_description'],
          ['beef-pie-small', 'Beef Pie', 'pies', 'Small', '2.30', 'by_count', 'A classic beef pie.'],
        ];
        downloadCsvTable(rows, 'spearings-products-template.csv');
      });

      function downloadCsvTable(rows, filename) {
        var csv = rows
          .map(function (r) {
            return r
              .map(function (c) {
                return '"' + String(c).replace(/"/g, '""') + '"';
              })
              .join(',');
          })
          .join('\n');
        var blob = new Blob([csv], { type: 'text/csv' });
        var a = document.createElement('a');
        a.href = URL.createObjectURL(blob);
        a.download = filename;
        a.click();
      }

      document.getElementById('uploadCsvInputTable').addEventListener('change', function (e) {
        var file = e.target.files[0];
        if (!file) return;

        var reader = new FileReader();
        reader.onload = function () {
          var text = reader.result;
          fetch('/api/admin/products/csv', {
            method: 'POST',
            headers: { 'Content-Type': 'text/csv' },
            body: text,
          })
            .then(function (r) {
              return r.json();
            })
            .then(function (data) {
              if (data.ok) {
                markPublishPending();
                showToastTable('Updated ' + data.updated + ' products, created ' + data.created + ' new');
                setTimeout(function () {
                  location.reload();
                }, 1500);
              } else {
                showToastTable('Error: ' + (data.error || 'Upload failed'));
              }
            })
            .catch(function () {
              showToastTable('Upload failed');
            });
        };
        reader.readAsText(file);
        e.target.value = '';
      });

      window.addEventListener('beforeunload', function (e) {
        var dirty = false;
        document.querySelectorAll('.price-input').forEach(function (input) {
          if (String(input.value) !== String(input.dataset.original ?? '')) dirty = true;
        });
        if (dirty) {
          e.preventDefault();
          e.returnValue = '';
        }
      });

      function showToastTable(msg) {
        var el = document.createElement('div');
        el.className = 'admin-toast';
        el.textContent = msg;
        document.body.appendChild(el);
        setTimeout(function () {
          el.remove();
        }, 2500);
      }
    </script>
  )}
</AdminLayout>

