---
import AdminLayout from '../../layouts/AdminLayout.astro';
import { getAdminFromRequest } from '../../lib/admin-auth';
import { supabaseAdmin } from '../../lib/supabase-server';

const admin = getAdminFromRequest(Astro.request);
if (!admin) return Astro.redirect('/admin/login');

const { data: blockedDates } = await supabaseAdmin
  .from('order_dates_blocked')
  .select('id, blocked_date, reason')
  .order('blocked_date', { ascending: true });

const dateList = blockedDates ?? [];
const today = new Date().toISOString().slice(0, 10);
const futureDates = dateList.filter((d: any) => d.blocked_date >= today);
const pastDates = dateList.filter((d: any) => d.blocked_date < today);
---

<AdminLayout title="Date Manager" activeNav="dates">
  <div class="admin-toolbar">
    <p style="margin:0;color:rgba(26,26,24,0.55);font-size:0.88rem;">
      Block dates to prevent customers from ordering for collection/delivery on those days.
    </p>
    <p style="margin:0.5rem 0 0;color:rgba(26,26,24,0.5);font-size:0.85rem;">
      To show a site-wide message (e.g. summer closure), use{' '}
      <a href="/admin/promo" style="color:#1f5a3a;font-weight:600;">Site pop-up</a>.
    </p>
  </div>

  <div class="admin-card">
    <h2>Block New Dates</h2>
    <form id="blockDateForm" style="display:flex;gap:0.75rem;align-items:end;flex-wrap:wrap;">
      <div class="admin-form-group" style="margin-bottom:0;">
        <label for="blockFrom">From</label>
        <input type="date" id="blockFrom" class="admin-input" min={today} required style="width:auto;" />
      </div>
      <div class="admin-form-group" style="margin-bottom:0;">
        <label for="blockTo">To</label>
        <input type="date" id="blockTo" class="admin-input" min={today} style="width:auto;" />
      </div>
      <div class="admin-form-group" style="margin-bottom:0;">
        <label for="blockReason">Reason</label>
        <input type="text" id="blockReason" class="admin-input" placeholder="e.g. Bank Holiday" style="width:14rem;" />
      </div>
      <button type="submit" class="admin-btn admin-btn-primary">Block Dates</button>
    </form>
  </div>

  <div class="admin-card">
    <h2>Upcoming Blocked Dates ({futureDates.length})</h2>
    {futureDates.length === 0 ? (
      <div class="admin-empty">No upcoming blocked dates.</div>
    ) : (
      <table class="admin-table">
        <thead>
          <tr>
            <th>Date</th>
            <th>Day</th>
            <th>Reason</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody id="futureDatesBody">
          {futureDates.map((d: any) => (
            <tr data-date-id={d.id}>
              <td><strong>{d.blocked_date}</strong></td>
              <td>{new Date(d.blocked_date + 'T12:00:00').toLocaleDateString('en-GB', { weekday: 'long' })}</td>
              <td class="closure-reason-cell">{d.reason ?? '—'}</td>
              <td>
                <div style="display:flex;gap:0.5rem;flex-wrap:wrap;">
                  <button
                    type="button"
                    class="admin-btn admin-btn-sm edit-closure-btn"
                    data-date-id={d.id}
                    data-blocked-date={d.blocked_date}
                  >
                    Edit
                  </button>
                  <button type="button" class="admin-btn admin-btn-sm admin-btn-danger unblock-btn" data-date-id={d.id}>
                    Unblock
                  </button>
                </div>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    )}
  </div>

  <dialog id="editClosureDialog" class="closure-edit-dialog">
    <form id="editClosureForm" class="closure-edit-form">
      <h2 style="margin:0 0 1rem;font-size:1.15rem;">Edit closure</h2>
      <p style="margin:0 0 1rem;font-size:0.88rem;color:rgba(26,26,24,0.55);">
        Change the blocked date or the reason shown to staff. Saving a date that is already blocked elsewhere will fail.
      </p>
      <input type="hidden" id="editClosureId" />
      <div class="admin-form-group">
        <label for="editClosureDate">Blocked date</label>
        <input type="date" id="editClosureDate" class="admin-input" required />
      </div>
      <div class="admin-form-group">
        <label for="editClosureReason">Reason</label>
        <input type="text" id="editClosureReason" class="admin-input" placeholder="e.g. Bank Holiday" />
      </div>
      <div style="display:flex;gap:0.75rem;justify-content:flex-end;margin-top:1.25rem;">
        <button type="button" class="admin-btn" id="editClosureCancel">Cancel</button>
        <button type="submit" class="admin-btn admin-btn-primary">Save changes</button>
      </div>
    </form>
  </dialog>

  {pastDates.length > 0 && (
    <div class="admin-card">
      <h2>Past Blocked Dates ({pastDates.length})</h2>
      <details>
        <summary style="cursor:pointer;font-size:0.85rem;color:rgba(26,26,24,0.5);">Show past dates</summary>
        <table class="admin-table" style="margin-top:0.75rem;">
          <thead>
            <tr><th>Date</th><th>Reason</th></tr>
          </thead>
          <tbody>
            {pastDates.map((d: any) => (
              <tr>
                <td>{d.blocked_date}</td>
                <td>{d.reason ?? '—'}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </details>
    </div>
  )}
</AdminLayout>

<style>
  .closure-edit-dialog {
    border: none;
    border-radius: var(--admin-radius, 12px);
    padding: 0;
    max-width: 26rem;
    box-shadow: 0 24px 60px rgba(0, 0, 0, 0.2);
  }
  .closure-edit-dialog::backdrop {
    background: rgba(14, 35, 24, 0.45);
  }
  .closure-edit-form {
    padding: 1.5rem;
  }
</style>

<script is:inline>
  document.getElementById('blockDateForm').addEventListener('submit', function(e) {
    e.preventDefault();
    var from = document.getElementById('blockFrom').value;
    var to = document.getElementById('blockTo').value || from;
    var reason = document.getElementById('blockReason').value;

    if (!from) return;
    if (to < from) to = from;

    fetch('/api/admin/dates', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ from: from, to: to, reason: reason })
    }).then(function(r) { return r.json(); }).then(function(data) {
      if (data.ok) {
        showToast('Blocked ' + data.count + ' date(s)');
        setTimeout(function() { location.reload(); }, 1000);
      } else { showToast('Error: ' + data.error); }
    });
  });

  var editDialog = document.getElementById('editClosureDialog');
  var editForm = document.getElementById('editClosureForm');
  var editCancel = document.getElementById('editClosureCancel');

  document.querySelectorAll('.edit-closure-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var tr = btn.closest('tr');
      var tds = tr.querySelectorAll('td');
      var reasonCell = tds[2];
      var reason = reasonCell ? reasonCell.textContent.trim() : '';
      if (reason === '—') reason = '';
      document.getElementById('editClosureId').value = btn.dataset.dateId;
      document.getElementById('editClosureDate').value = btn.dataset.blockedDate || '';
      document.getElementById('editClosureReason').value = reason;
      if (editDialog) editDialog.showModal();
    });
  });

  if (editCancel && editDialog) {
    editCancel.addEventListener('click', function() {
      editDialog.close();
    });
  }

  if (editForm) {
    editForm.addEventListener('submit', function(e) {
      e.preventDefault();
      var id = document.getElementById('editClosureId').value;
      var blocked_date = document.getElementById('editClosureDate').value;
      var reason = document.getElementById('editClosureReason').value;
      fetch('/api/admin/dates', {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: id, blocked_date: blocked_date, reason: reason }),
      })
        .then(function(r) {
          return r.json().then(function(data) {
            return { ok: r.ok, data: data };
          });
        })
        .then(function(res) {
          if (res.ok) {
            if (editDialog) editDialog.close();
            showToast('Closure updated');
            setTimeout(function() {
              location.reload();
            }, 600);
          } else {
            showToast(res.data.error || 'Update failed');
          }
        });
    });
  }

  document.querySelectorAll('.unblock-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var id = btn.dataset.dateId;
      fetch('/api/admin/dates', {
        method: 'DELETE',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: id })
      }).then(function(r) {
        if (r.ok) {
          btn.closest('tr').remove();
          showToast('Date unblocked');
        } else { showToast('Failed to unblock'); }
      });
    });
  });

  function showToast(msg) {
    var el = document.createElement('div');
    el.className = 'admin-toast';
    el.textContent = msg;
    document.body.appendChild(el);
    setTimeout(function() { el.remove(); }, 2500);
  }
</script>
