---
export const prerender = true;
import Layout from '../layouts/Layout.astro';

const mapsSearchUrl =
  'https://www.google.com/maps/search/?api=1&query=Spearings+Butchers+12+Park+Green+Macclesfield+SK11+7NA';
---

<Layout
  title="Delivery Service | Spearings Butchers"
  description="Spearings delivery within Macclesfield and surrounding areas — areas covered, charges, times, and how to order."
  path="/delivery"
>
  <main>
    <section class="page-hero delivery-hero">
      <div class="container page-hero-inner delivery-hero-grid">
        <div class="page-hero-copy stack reveal-up reveal-delay-1">
          <div class="page-hero-badge">
            <span class="badge-year">Delivery</span>
            <span>12 Park Green, Macclesfield</span>
          </div>
          <h1>Delivery <em>service</em></h1>
          <p class="body-lead">
            Make life simpler with our delivery service — perfect if you are at work, home, in an office, or running a
            business.
          </p>
        </div>

        <div class="page-visual reveal-up reveal-delay-2">
          <div class="page-image-frame delivery-van-frame">
            <img
              src="/images/spearings-delivery-van.png"
              alt="Spearings branded delivery van"
              width="1600"
              height="900"
              loading="eager"
            />
          </div>
        </div>
      </div>
    </section>

    <section class="section section-cream">
      <div class="container delivery-content">
        <article class="delivery-section reveal-up">
          <p class="eyebrow">Areas covered</p>
          <h2>Where we deliver</h2>
          <p>
            We deliver within a <strong>5 mile</strong> radius of the shop at standard rates, and between <strong
              >5 and 10 miles</strong
            >
            for an extended-area charge. If you live outside our delivery area, please contact us before placing an order.
          </p>
          <p>
            <a href={mapsSearchUrl} class="card-link" rel="noopener noreferrer" target="_blank"
              >Open the map for our shop location</a
            >
            — below is an overview of our delivery limits (straight-line distance from the shop, not driving miles).
          </p>
          <a href="/images/delivery-radius.png" class="delivery-map-link" target="_blank" rel="noopener noreferrer">
            <span class="delivery-map-thumb-wrap">
              <img
                src="/images/delivery-radius.png"
                alt="Map overview of Spearings delivery area around Macclesfield"
                width="1200"
                height="628"
                loading="lazy"
              />
            </span>
            <span class="delivery-map-cta">View full-size map</span>
          </a>
        </article>

        <article class="delivery-section reveal-up reveal-delay-1">
          <p class="eyebrow">How to order</p>
          <h2>Ordering &amp; lead times</h2>
          <ul class="bullet-list">
            <li>Please allow up to <strong>2 working days</strong> for orders placed over the phone or through the website.</li>
            <li>Payment can be made over the phone or on delivery.</li>
            <li>
              Pie orders can be placed online — <a href="/pies" class="inline-link">order pies here</a>.
            </li>
          </ul>
        </article>

        <article class="delivery-section reveal-up reveal-delay-2">
          <p class="eyebrow">Contact us</p>
          <h2>Get in touch</h2>
          <ul class="contact-list delivery-contact">
            <li><strong>Phone:</strong> <a href="tel:01625424395">01625 424395</a></li>
            <li><strong>Email:</strong> <a href="mailto:spearingsbutchers@gmail.com">spearingsbutchers@gmail.com</a></li>
            <li><strong>Pies:</strong> <a href="mailto:pies@spearings.co.uk">pies@spearings.co.uk</a></li>
          </ul>
        </article>

        <article class="delivery-section delivery-charges reveal-up">
          <p class="eyebrow">Pricing</p>
          <h2>Is there a charge?</h2>
          <ul class="bullet-list">
            <li>
              <strong>Within 5 miles of the shop:</strong> free delivery on orders of <strong>£30 or more</strong>.
              Orders under £30 are charged <strong>£5</strong> delivery.
            </li>
            <li>
              <strong>Between 5 and 10 miles:</strong> a <strong>£15</strong> delivery charge applies (straight-line
              distance from the shop).
            </li>
            <li>We cannot fulfil standard delivery orders beyond <strong>10 miles</strong> of the shop — please call us to discuss.</li>
          </ul>
        </article>

        <article class="delivery-section reveal-up">
          <p class="eyebrow">Times</p>
          <h2>Delivery times</h2>
          <p>
            Deliveries are made between <strong>7:30am and 1:00pm</strong>, Tuesday to Saturday. We do not offer
            specific time slots.
          </p>
        </article>

        <p class="delivery-back reveal-up">
          <a href="/visit" class="card-link">Visit us in person</a>
          <span class="delivery-back-sep">·</span>
          <a href="/pies" class="btn btn-green btn-sm">Order pies</a>
        </p>
      </div>
    </section>
  </main>
</Layout>

<style>
  .delivery-hero-grid {
    align-items: center;
  }

  .delivery-van-frame {
    border-radius: var(--radius-xl);
    overflow: hidden;
    background: linear-gradient(165deg, rgba(255, 255, 255, 0.95) 0%, rgba(250, 248, 242, 0.9) 100%);
    border: 1px solid rgba(26, 26, 24, 0.08);
    box-shadow: 0 16px 48px rgba(26, 26, 24, 0.08);
  }

  .delivery-van-frame img {
    display: block;
    width: 100%;
    height: auto;
    object-fit: contain;
  }

  .delivery-content {
    max-width: 44rem;
  }

  .delivery-section {
    margin-bottom: 2.5rem;
  }

  .delivery-section h2 {
    margin: 0.35rem 0 0.75rem;
    font-size: clamp(1.35rem, 2.2vw, 1.65rem);
  }

  .delivery-section p,
  .delivery-section li {
    font-size: 0.98rem;
    line-height: 1.65;
    color: rgba(26, 26, 24, 0.88);
  }

  .delivery-map-link {
    display: block;
    margin-top: 1.25rem;
    text-decoration: none;
    color: inherit;
    border-radius: var(--radius-lg);
    overflow: hidden;
    border: 1px solid rgba(26, 26, 24, 0.1);
    box-shadow: 0 8px 28px rgba(26, 26, 24, 0.08);
    transition:
      box-shadow 0.2s,
      transform 0.2s;
  }

  .delivery-map-link:hover {
    box-shadow: 0 12px 36px rgba(26, 26, 24, 0.12);
    transform: translateY(-2px);
  }

  .delivery-map-thumb-wrap img {
    display: block;
    width: 100%;
    height: auto;
  }

  .delivery-map-cta {
    display: block;
    padding: 0.65rem 1rem;
    font-size: 0.88rem;
    font-weight: 600;
    text-align: center;
    background: rgba(14, 35, 24, 0.06);
    color: var(--g-700);
  }

  .delivery-contact a {
    color: var(--g-700);
    font-weight: 600;
  }

  .inline-link {
    font-weight: 600;
    color: var(--g-700);
    text-decoration: underline;
    text-underline-offset: 0.15em;
  }

  .delivery-back {
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(26, 26, 24, 0.08);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.75rem 1rem;
  }

  .delivery-back-sep {
    color: rgba(26, 26, 24, 0.35);
  }

  @media (max-width: 900px) {
    .delivery-hero .page-hero-inner {
      grid-template-columns: 1fr;
    }
  }
</style>
