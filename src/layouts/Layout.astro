---
import '../styles/site.css';

interface Props {
	title?: string;
	description?: string;
	path?: string;
}

const {
	title = 'Spearings Butchers | Macclesfield Since 1945',
	description = 'Traditional family butchers in Macclesfield, serving local meat, handmade pies, deli produce, and cheese since 1945.',
	path = '/',
} = Astro.props;

const navigation = [
	{ href: '/our-story', label: 'Our Story' },
	{ href: '/products', label: 'Products' },
	{ href: '/pies', label: 'Pies' },
	{ href: '/visit', label: 'Visit' },
];

const openingHours = [
	'Monday 6:30am to 2:00pm',
	'Tuesday 6:30am to 2:00pm',
	'Wednesday 6:30am to 1:00pm',
	'Thursday 6:30am to 2:00pm',
	'Friday 6:30am to 2:00pm',
	'Saturday 6:30am to 1:30pm',
];
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<meta name="theme-color" content="#102015" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
		<link
			href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:wght@300;400;500;600;700&display=swap"
			rel="stylesheet"
		/>
		<title>{title}</title>
	</head>
	<body>
		<header class="site-header" id="siteHeader">
			<div class="container nav-wrap">
				<a href="/" class="brand" aria-label="Spearings Butchers Home">
					<span class="brand-logo-shell">
						<img
							class="brand-logo brand-logo-header brand-logo-header-crest"
							src="/images/crest-logo-header-new.png"
							alt="Spearings Quality Family Butcher logo"
						/>
					</span>
				</a>

				<nav class="site-nav" aria-label="Primary navigation">
					{
						navigation.map((item) => (
							<a href={item.href} class={path === item.href ? 'active' : undefined}>
								{item.label}
							</a>
						))
					}
				</nav>

				<a href="/pies" class="pie-shortcut" aria-label="Order pies online">
					<svg viewBox="0 0 24 24" aria-hidden="true">
						<path
							d="M4.5 18.5h15a1 1 0 0 0 .9-1.43l-5.2-10.4a1 1 0 0 0-.9-.57H9.7a1 1 0 0 0-.9.57L3.6 17.07a1 1 0 0 0 .9 1.43Z"
							fill="currentColor"
						></path>
						<path
							d="M12 6.2v12.3"
							stroke="rgba(8,22,17,0.55)"
							stroke-linecap="round"
							stroke-width="1.4"
						></path>
						<path
							d="M8.7 11.2h6.6"
							stroke="rgba(8,22,17,0.55)"
							stroke-linecap="round"
							stroke-width="1.4"
						></path>
						<circle cx="9.2" cy="9.2" r="1" fill="rgba(8,22,17,0.45)"></circle>
						<circle cx="14.6" cy="13.8" r="1" fill="rgba(8,22,17,0.45)"></circle>
					</svg>
					<span>Pies</span>
				</a>

				<button
					type="button"
					class="mobile-nav-toggle"
					id="mobileNavToggle"
					aria-expanded="false"
					aria-controls="mobileNavPanel"
					aria-label="Open navigation menu"
				>
					<span class="mobile-nav-toggle-label">Menu</span>
					<span class="mobile-nav-toggle-bars" aria-hidden="true">
						<span></span>
						<span></span>
						<span></span>
					</span>
				</button>

				<a href="/pies" class="btn btn-gold btn-sm">Order Pies</a>
			</div>

			<div class="mobile-nav-shell" id="mobileNavShell" hidden>
				<nav class="container mobile-nav-panel" id="mobileNavPanel" aria-label="Mobile navigation">
					{
						navigation.map((item) => (
							<a href={item.href} class={path === item.href ? 'active' : undefined}>
								{item.label}
							</a>
						))
					}

					<a href="/pies" class="btn btn-gold mobile-nav-cta">Order Pies</a>
				</nav>
			</div>
		</header>

		<slot />

		<footer class="site-footer">
			<div class="container footer-inner">
				<div class="footer-brand-row">
					<div class="footer-brand">
						<span class="brand-logo-shell brand-logo-shell-footer">
							<img
								class="brand-logo brand-logo-footer"
								src="/images/crest-logo-black.png"
								alt="Spearings Quality Family Butcher logo"
							/>
						</span>
						<div>
							<strong>Spearings Butchers</strong>
							<small>Macclesfield since 1945</small>
						</div>
					</div>

					<a
						href="https://www.facebook.com/people/Spearings-Butchers/100063608560341/"
						class="btn btn-gold btn-sm footer-social"
						target="_blank"
						rel="noreferrer"
					>
						Follow on Facebook
					</a>
				</div>

				<div class="footer-info-grid">
					<section class="footer-panel">
						<p class="footer-heading">Opening Times</p>
						<ul class="footer-list">
							{openingHours.map((slot) => <li>{slot}</li>)}
						</ul>
					</section>

					<section class="footer-panel">
						<p class="footer-heading">Email Us</p>
						<ul class="footer-list">
							<li>
								<a href="mailto:spearingsbutchers@gmail.com">spearingsbutchers@gmail.com</a>
							</li>
							<li>
								<a href="mailto:pies@spearings.co.uk">pies@spearings.co.uk</a>
							</li>
						</ul>
					</section>

					<section class="footer-panel">
						<p class="footer-heading">Phone & Location</p>
						<ul class="footer-list">
							<li>
								<a href="tel:01625424395">01625 424395</a>
							</li>
							<li>12 Park Green, Macclesfield</li>
							<li>Cheshire, SK11 7NA</li>
						</ul>
					</section>

					<section class="footer-panel footer-panel-social">
						<p class="footer-heading">Facebook</p>
						<p class="footer-copy-social">
							Weekly updates, pie news, and shop announcements are best surfaced on Facebook.
						</p>
						<a
							href="https://www.facebook.com/people/Spearings-Butchers/100063608560341/"
							class="card-link footer-facebook-link"
							target="_blank"
							rel="noreferrer"
						>
							See latest updates
						</a>
					</section>
				</div>

				<div class="footer-meta">
					<nav class="footer-nav" aria-label="Footer navigation">
						{
							navigation.map((item) => (
								<a href={item.href}>{item.label}</a>
							))
						}
					</nav>

					<p class="footer-copy">
						&copy; 2026 Spearings Butchers Ltd. 12 Park Green, Macclesfield SK11 7NA.
					</p>
				</div>
			</div>
		</footer>
		<script is:inline>
			(() => {
				const header = document.getElementById('siteHeader');
				const mobileNavToggle = document.getElementById('mobileNavToggle');
				const mobileNavShell = document.getElementById('mobileNavShell');
				const mobileNavPanel = document.getElementById('mobileNavPanel');
				const handleScroll = () => {
					header?.classList.toggle('scrolled', window.scrollY > 40);
				};

				const closeMobileNav = () => {
					header?.classList.remove('menu-open');
					mobileNavToggle?.setAttribute('aria-expanded', 'false');
					mobileNavToggle?.setAttribute('aria-label', 'Open navigation menu');
					if (mobileNavShell) {
						mobileNavShell.hidden = true;
					}
				};

				const toggleMobileNav = () => {
					const isOpen = header?.classList.toggle('menu-open');
					const nextExpanded = isOpen ? 'true' : 'false';
					mobileNavToggle?.setAttribute('aria-expanded', nextExpanded);
					mobileNavToggle?.setAttribute(
						'aria-label',
						isOpen ? 'Close navigation menu' : 'Open navigation menu',
					);

					if (mobileNavShell) {
						mobileNavShell.hidden = !isOpen;
					}
				};

				handleScroll();
				window.addEventListener('scroll', handleScroll, { passive: true });
				mobileNavToggle?.addEventListener('click', toggleMobileNav);
				mobileNavPanel?.querySelectorAll('a').forEach((link) => {
					link.addEventListener('click', closeMobileNav);
				});
				window.addEventListener('resize', () => {
					if (window.innerWidth > 980) {
						closeMobileNav();
					}
				});
				window.addEventListener('keydown', (event) => {
					if (event.key === 'Escape') {
						closeMobileNav();
					}
				});

				const revealElements = document.querySelectorAll(
					'.reveal, .reveal-up, .reveal-scale, .reveal-left, .reveal-right',
				);

				if (!revealElements.length || window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
					revealElements.forEach((element) => element.classList.add('visible'));
					return;
				}

				const observer = new IntersectionObserver(
					(entries) => {
						entries.forEach((entry) => {
							if (!entry.isIntersecting) return;
							entry.target.classList.add('visible');
							observer.unobserve(entry.target);
						});
					},
					{
						threshold: 0.12,
						rootMargin: '0px 0px -60px 0px',
					},
				);

				revealElements.forEach((element) => observer.observe(element));
			})();
		</script>
	</body>
</html>
