---
import { formatPrice, isOnlineOrderable, type Category, type Product } from '../lib/catalog';

interface CategorySection {
  category: Category;
  description: string;
  products: Product[];
}

interface Props {
  sections: CategorySection[];
}

const { sections } = Astro.props;
const defaultSlug = sections[0]?.category.slug ?? '';
---

<div class="catalog-browser reveal-up" data-default-category={defaultSlug}>
  <div class="catalog-tabs" role="tablist" aria-label="Product categories">
    {
      sections.map((section, index) => (
        <button
          type="button"
          class="catalog-tab"
          role="tab"
          id={`tab-${section.category.slug}`}
          aria-controls={`panel-${section.category.slug}`}
          aria-selected={index === 0 ? 'true' : 'false'}
          data-category-target={section.category.slug}
        >
          <span>{section.category.name}</span>
          <small>{section.products.length} items</small>
        </button>
      ))
    }
  </div>

  <div class="catalog-accordion-list">
    {
      sections.map((section, index) => (
        <details
          class="catalog-accordion"
          data-category-panel={section.category.slug}
          open={index === 0}
        >
          <summary class="catalog-accordion-summary">
            <span>
              {section.category.name}
              <small>{section.products.length} items</small>
            </span>
          </summary>

          <div
            class="catalog-panel"
            id={`panel-${section.category.slug}`}
            role="tabpanel"
            aria-labelledby={`tab-${section.category.slug}`}
          >
            <div class="catalog-heading">
              <p class="eyebrow">{section.category.name}</p>
              <h2>{section.category.name} at Spearings</h2>
              <p class="body-lead">{section.description}</p>
            </div>

            <div class="catalog-grid">
              {section.products.map((product) => (
                <article class="catalog-card reveal-up">
                  {
                    isOnlineOrderable(product) ? (
                      <a href="/pies" class="catalog-card-media" aria-label={`Order ${product.name} online`}>
                        <img src={product.imageUrl ?? '/images/shop-interior.jpg'} alt={product.name} />
                      </a>
                    ) : (
                      <div class="catalog-card-media">
                        <img src={product.imageUrl ?? '/images/shop-interior.jpg'} alt={product.name} />
                      </div>
                    )
                  }

                  <div class="catalog-card-head">
                    <div>
                      <h3>{product.name}</h3>
                      <div class="catalog-meta">
                        <span class={`meta-pill ${isOnlineOrderable(product) ? 'orderable' : ''}`}>
                          {isOnlineOrderable(product) ? 'Order online' : 'Available in shop'}
                        </span>
                        {product.size && <span class="meta-pill">{product.size}</span>}
                      </div>
                    </div>

                    <div class="catalog-card-price">{formatPrice(product)}</div>
                  </div>

                  <p>{product.shortDescription ?? 'Ask in shop for today’s availability and preparation options.'}</p>

                  {isOnlineOrderable(product) && (
                    <a href="/pies" class="btn btn-green btn-sm catalog-card-action">Order Online</a>
                  )}
                </article>
              ))}
            </div>
          </div>
        </details>
      ))
    }
  </div>
</div>

<script is:inline>
  (() => {
    const desktopQuery = window.matchMedia('(min-width: 861px)');

    function setupBrowser(browser) {
      const defaultSlug = browser.dataset.defaultCategory;
      const tabs = Array.from(browser.querySelectorAll('[data-category-target]'));
      const panels = Array.from(browser.querySelectorAll('[data-category-panel]'));

      if (!defaultSlug || tabs.length === 0 || panels.length === 0) return;

      const setActive = (slug, updateHash = false) => {
        tabs.forEach((tab) => {
          const selected = tab.dataset.categoryTarget === slug;
          tab.setAttribute('aria-selected', selected ? 'true' : 'false');
          tab.toggleAttribute('data-active', selected);
        });

        panels.forEach((panel) => {
          panel.open = panel.dataset.categoryPanel === slug;
        });

        if (updateHash) {
          history.replaceState(null, '', `#${slug}`);
        }
      };

      tabs.forEach((tab) => {
        tab.addEventListener('click', () => {
          setActive(tab.dataset.categoryTarget, true);
        });
      });

      panels.forEach((panel) => {
        panel.addEventListener('toggle', () => {
          if (!panel.open) return;
          if (!desktopQuery.matches) return;
          setActive(panel.dataset.categoryPanel, true);
        });
      });

      const syncFromHash = () => {
        const hash = window.location.hash.replace('#', '');
        const requested = panels.some((panel) => panel.dataset.categoryPanel === hash)
          ? hash
          : defaultSlug;

        setActive(requested, false);
      };

      desktopQuery.addEventListener('change', syncFromHash);
      window.addEventListener('hashchange', syncFromHash);
      syncFromHash();
    }

    document.querySelectorAll('.catalog-browser').forEach(setupBrowser);
  })();
</script>
